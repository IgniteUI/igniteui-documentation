{
  "name": "docs-template",
  "type": "module",
  "version": "0.1.0",
  "workspaces": [
    "docs/angular",
    "docs/xplat"
  ],
  "description": "Shared Astro documentation framework for IgniteUI library docs",
  "exports": {
    "./integration": "./src/integration.ts",
    "./sidebar": "./src/sidebar.ts",
    "./platform": "./src/platform.ts",
    "./content": "./src/content-helper.ts",
    "./middleware": "./src/middleware.ts",
    "./lib/platform-context": "./src/lib/platform-context.ts",
    "./components/mdx/DownloadCard.astro": "./src/components/mdx/cards/DownloadCard.astro",
    "./components/mdx/DownloadCardGroup.astro": "./src/components/mdx/cards/DownloadCardGroup.astro",
    "./components/mdx/FaqAccordion.astro": "./src/components/mdx/FaqAccordion/FaqAccordion.astro",
    "./components/mdx/CtaArea.astro": "./src/components/mdx/CtaArea/CtaArea.astro",
    "./components/mdx/FeatureList.astro": "./src/components/mdx/FeatureList/FeatureList.astro",
    "./components/mdx/Feature.astro": "./src/components/mdx/Feature/Feature.astro",
    "./components/mdx/BrowserList.astro": "./src/components/mdx/BrowserList/BrowserList.astro"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "dev": "cross-env DOCS_ENV=development astro dev",
    "build": "astro build",
    "build:staging": "cross-env DOCS_ENV=staging astro build",
    "build:prod": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "build:staging:angular:en": "npm run build-staging:en --prefix docs/angular",
    "build:staging:angular:jp": "npm run build-staging:jp --prefix docs/angular",
    "build:staging:react:en": "npm run build-staging:react --prefix docs/xplat",
    "build:staging:react:jp": "npm run build-staging:react:jp --prefix docs/xplat",
    "build:staging:wc:en": "npm run build-staging:webcomponents --prefix docs/xplat",
    "build:staging:wc:jp": "npm run build-staging:webcomponents:jp --prefix docs/xplat",
    "build:staging:blazor:en": "npm run build-staging:blazor --prefix docs/xplat",
    "build:staging:blazor:jp": "npm run build-staging:blazor:jp --prefix docs/xplat",
    "build:production:angular:en": "npm run build-production:en --prefix docs/angular",
    "build:production:angular:jp": "npm run build-production:jp --prefix docs/angular",
    "build:production:react:en": "npm run build-production:react --prefix docs/xplat",
    "build:production:react:jp": "npm run build-production:react:jp --prefix docs/xplat",
    "build:production:wc:en": "npm run build-production:webcomponents --prefix docs/xplat",
    "build:production:wc:jp": "npm run build-production:webcomponents:jp --prefix docs/xplat",
    "build:production:blazor:en": "npm run build-production:blazor --prefix docs/xplat",
    "build:production:blazor:jp": "npm run build-production:blazor:jp --prefix docs/xplat",
    "angular:dev": "npm run dev --prefix docs/angular",
    "angular:dev:en": "npm run dev:en --prefix docs/angular",
    "angular:dev:jp": "npm run dev:jp --prefix docs/angular",
    "angular:dev:kr": "npm run dev:kr --prefix docs/angular",
    "angular:build": "npm run build --prefix docs/angular",
    "angular:build:en": "npm run build:en --prefix docs/angular",
    "angular:build:jp": "npm run build:jp --prefix docs/angular",
    "angular:build:kr": "npm run build:kr --prefix docs/angular",
    "angular:build-staging": "npm run build-staging --prefix docs/angular",
    "angular:build-staging:en": "npm run build-staging:en --prefix docs/angular",
    "angular:build-staging:jp": "npm run build-staging:jp --prefix docs/angular",
    "angular:build-staging:kr": "npm run build-staging:kr --prefix docs/angular",
    "angular:build-production": "npm run build-production --prefix docs/angular",
    "angular:build-production:en": "npm run build-production:en --prefix docs/angular",
    "angular:build-production:jp": "npm run build-production:jp --prefix docs/angular",
    "angular:build-production:kr": "npm run build-production:kr --prefix docs/angular",
    "angular:preview": "npm run preview --prefix docs/angular",
    "angular:preview:en": "npm run preview:en --prefix docs/angular",
    "angular:preview:jp": "npm run preview:jp --prefix docs/angular",
    "angular:preview:kr": "npm run preview:kr --prefix docs/angular",
    "xplat:dev": "npm run dev --prefix docs/xplat",
    "xplat:dev:angular": "npm run dev:angular --prefix docs/xplat",
    "xplat:dev:react": "npm run dev:react --prefix docs/xplat",
    "xplat:dev:webcomponents": "npm run dev:webcomponents --prefix docs/xplat",
    "xplat:dev:blazor": "npm run dev:blazor --prefix docs/xplat",
    "xplat:dev:angular:jp": "npm run dev:angular:jp --prefix docs/xplat",
    "xplat:dev:react:jp": "npm run dev:react:jp --prefix docs/xplat",
    "xplat:dev:webcomponents:jp": "npm run dev:webcomponents:jp --prefix docs/xplat",
    "xplat:dev:blazor:jp": "npm run dev:blazor:jp --prefix docs/xplat",
    "xplat:preview": "npm run preview --prefix docs/xplat",
    "xplat:preview:angular": "npm run preview:angular --prefix docs/xplat",
    "xplat:preview:react": "npm run preview:react --prefix docs/xplat",
    "xplat:preview:webcomponents": "npm run preview:webcomponents --prefix docs/xplat",
    "xplat:preview:blazor": "npm run preview:blazor --prefix docs/xplat",
    "xplat:preview:angular:jp": "npm run preview:angular:jp --prefix docs/xplat",
    "xplat:preview:react:jp": "npm run preview:react:jp --prefix docs/xplat",
    "xplat:preview:webcomponents:jp": "npm run preview:webcomponents:jp --prefix docs/xplat",
    "xplat:preview:blazor:jp": "npm run preview:blazor:jp --prefix docs/xplat",
    "xplat:build:angular": "npm run build:angular --prefix docs/xplat",
    "xplat:build:react": "npm run build:react --prefix docs/xplat",
    "xplat:build:webcomponents": "npm run build:webcomponents --prefix docs/xplat",
    "xplat:build:blazor": "npm run build:blazor --prefix docs/xplat",
    "xplat:build:angular:jp": "npm run build:angular:jp --prefix docs/xplat",
    "xplat:build:react:jp": "npm run build:react:jp --prefix docs/xplat",
    "xplat:build:webcomponents:jp": "npm run build:webcomponents:jp --prefix docs/xplat",
    "xplat:build:blazor:jp": "npm run build:blazor:jp --prefix docs/xplat",
    "xplat:build-staging:angular": "npm run build-staging:angular --prefix docs/xplat",
    "xplat:build-staging:react": "npm run build-staging:react --prefix docs/xplat",
    "xplat:build-staging:webcomponents": "npm run build-staging:webcomponents --prefix docs/xplat",
    "xplat:build-staging:blazor": "npm run build-staging:blazor --prefix docs/xplat",
    "xplat:build-staging:angular:jp": "npm run build-staging:angular:jp --prefix docs/xplat",
    "xplat:build-staging:react:jp": "npm run build-staging:react:jp --prefix docs/xplat",
    "xplat:build-staging:webcomponents:jp": "npm run build-staging:webcomponents:jp --prefix docs/xplat",
    "xplat:build-staging:blazor:jp": "npm run build-staging:blazor:jp --prefix docs/xplat",
    "xplat:build-production:angular": "npm run build-production:angular --prefix docs/xplat",
    "xplat:build-production:react": "npm run build-production:react --prefix docs/xplat",
    "xplat:build-production:webcomponents": "npm run build-production:webcomponents --prefix docs/xplat",
    "xplat:build-production:blazor": "npm run build-production:blazor --prefix docs/xplat",
    "xplat:build-production:angular:jp": "npm run build-production:angular:jp --prefix docs/xplat",
    "xplat:build-production:react:jp": "npm run build-production:react:jp --prefix docs/xplat",
    "xplat:build-production:webcomponents:jp": "npm run build-production:webcomponents:jp --prefix docs/xplat",
    "xplat:build-production:blazor:jp": "npm run build-production:blazor:jp --prefix docs/xplat",
    "lint:md": "markdownlint \"docs/**/*.mdx\" \"docs/**/*.md\"",
    "lint:md:fix": "markdownlint --fix \"docs/**/*.mdx\" \"docs/**/*.md\"",
    "spellcheck": "cspell \"docs/**/*.mdx\" \"docs/**/*.md\" --no-progress",
    "verify": "npm run spellcheck && npm run lint:md",
    "release:labels": "node scripts/release-labels.mjs",
    "release:labels:dry": "node scripts/release-labels.mjs --dry-run",
    "release:labels:angular": "node scripts/release-labels.mjs --platform=Angular",
    "release:labels:react": "node scripts/release-labels.mjs --platform=React",
    "release:labels:wc": "node scripts/release-labels.mjs --platform=WebComponents",
    "release:labels:blazor": "node scripts/release-labels.mjs --platform=Blazor",
    "check-api-links": "node scripts/check-api-links.mjs",
    "check-api-links:angular": "node scripts/check-api-links.mjs --platform=angular",
    "check-api-links:react": "node scripts/check-api-links.mjs --platform=react",
    "check-api-links:wc": "node scripts/check-api-links.mjs --platform=wc",
    "check-api-links:blazor": "node scripts/check-api-links.mjs --platform=blazor",
    "check-api-links:report": "node scripts/check-api-links.mjs --md=reports/api-link-report.md",
    "check-api-links:report:angular": "node scripts/check-api-links.mjs --platform=angular --md=reports/api-link-report-angular.md",
    "check-api-links:report:react": "node scripts/check-api-links.mjs --platform=react --md=reports/api-link-report-react.md",
    "check-api-links:report:wc": "node scripts/check-api-links.mjs --platform=wc --md=reports/api-link-report-wc.md",
    "check-api-links:report:blazor": "node scripts/check-api-links.mjs --platform=blazor --md=reports/api-link-report-blazor.md",
    "check-mdx-links": "node --experimental-strip-types scripts/check-mdx-links.mjs --list-ambiguities --ambiguity-md=reports/api-link-ambiguity-report.md --fail-on-ambiguity",
    "check-mdx-links:angular": "node --experimental-strip-types scripts/check-mdx-links.mjs --platform=angular --list-ambiguities --ambiguity-md=reports/api-link-ambiguity-report-angular.md --fail-on-ambiguity",
    "check-mdx-links:react": "node --experimental-strip-types scripts/check-mdx-links.mjs --platform=react --list-ambiguities --ambiguity-md=reports/api-link-ambiguity-report-react.md --fail-on-ambiguity",
    "check-mdx-links:wc": "node --experimental-strip-types scripts/check-mdx-links.mjs --platform=wc --list-ambiguities --ambiguity-md=reports/api-link-ambiguity-report-wc.md --fail-on-ambiguity",
    "check-mdx-links:blazor": "node --experimental-strip-types scripts/check-mdx-links.mjs --platform=blazor --list-ambiguities --ambiguity-md=reports/api-link-ambiguity-report-blazor.md --fail-on-ambiguity",
    "check-mdx-links:report": "node --experimental-strip-types scripts/check-mdx-links.mjs --md=reports/mdx-link-report.md --list-ambiguities --ambiguity-md=reports/api-link-ambiguity-report.md --fail-on-ambiguity",
    "check-mdx-links:report:angular": "node --experimental-strip-types scripts/check-mdx-links.mjs --platform=angular --md=reports/mdx-link-report-angular.md --list-ambiguities --ambiguity-md=reports/api-link-ambiguity-report-angular.md --fail-on-ambiguity",
    "check-mdx-links:report:react": "node --experimental-strip-types scripts/check-mdx-links.mjs --platform=react --md=reports/mdx-link-report-react.md --list-ambiguities --ambiguity-md=reports/api-link-ambiguity-report-react.md --fail-on-ambiguity",
    "check-mdx-links:report:wc": "node --experimental-strip-types scripts/check-mdx-links.mjs --platform=wc --md=reports/mdx-link-report-wc.md --list-ambiguities --ambiguity-md=reports/api-link-ambiguity-report-wc.md --fail-on-ambiguity",
    "check-mdx-links:report:blazor": "node --experimental-strip-types scripts/check-mdx-links.mjs --platform=blazor --md=reports/mdx-link-report-blazor.md --list-ambiguities --ambiguity-md=reports/api-link-ambiguity-report-blazor.md --fail-on-ambiguity",
    "check-mdx-links:broken": "node --experimental-strip-types scripts/check-mdx-links.mjs --resolve-only --list-broken --broken-limit=100 --broken-md=reports/mdx-broken-links.md --list-ambiguities --ambiguity-md=reports/api-link-ambiguity-report.md --fail-on-ambiguity",
    "check-mdx-links:broken:angular": "node --experimental-strip-types scripts/check-mdx-links.mjs --platform=angular --resolve-only --list-broken --broken-limit=100 --broken-md=reports/mdx-broken-links-angular.md --list-ambiguities --ambiguity-md=reports/api-link-ambiguity-report-angular.md --fail-on-ambiguity",
    "check-mdx-links:broken:react": "node --experimental-strip-types scripts/check-mdx-links.mjs --platform=react --resolve-only --list-broken --broken-limit=100 --broken-md=reports/mdx-broken-links-react.md --list-ambiguities --ambiguity-md=reports/api-link-ambiguity-report-react.md --fail-on-ambiguity",
    "check-mdx-links:broken:wc": "node --experimental-strip-types scripts/check-mdx-links.mjs --platform=wc --resolve-only --list-broken --broken-limit=100 --broken-md=reports/mdx-broken-links-wc.md --list-ambiguities --ambiguity-md=reports/api-link-ambiguity-report-wc.md --fail-on-ambiguity",
    "check-mdx-links:broken:blazor": "node --experimental-strip-types scripts/check-mdx-links.mjs --platform=blazor --resolve-only --list-broken --broken-limit=100 --broken-md=reports/mdx-broken-links-blazor.md --list-ambiguities --ambiguity-md=reports/api-link-ambiguity-report-blazor.md --fail-on-ambiguity"
  },
  "dependencies": {
    "@astrojs/mdx": ">=5",
    "astro-seo-schema": "^6.0.0",
    "gray-matter": "^4.0.3",
    "igniteui-astro-components": "0.0.24",
    "igniteui-webcomponents": "^7.1.3",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.0.1",
    "pagefind": "^1.5.2"
  },
  "devDependencies": {
    "@astrojs/ts-plugin": "^1.10.7",
    "@types/jsdom": "^28.0.1",
    "astro": "^6.1.6",
    "cross-env": "^10.1.0",
    "cspell": "^9.2.2",
    "igniteui-theming": "^25.0.2",
    "markdownlint-cli": "^0.48.0",
    "pagefind": "^1.5.2",
    "sass-embedded": "^1.98.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "@astrojs/mdx": ">=5",
    "astro": ">=6"
  },
  "engines": {
    "node": ">=22.12.0"
  }
