{
  "name": "docs-template",
  "type": "module",
  "version": "0.1.0",
  "description": "Shared Astro + Starlight documentation framework for IgniteUI library docs",
  "workspaces": ["docs/xplat"],
  "exports": {
    "./integration": "./src/integration.ts",
    "./sidebar": "./src/sidebar.ts",
    "./platform": "./src/platform.ts",
    "./content": "./src/content-helper.ts",
    "./content-helper": "./src/content-helper.ts"
  },
  "scripts": {
    "dev": "cross-env DOCS_ENV=development astro dev",
    "build": "astro build",
    "build:staging": "cross-env DOCS_ENV=staging astro build",
    "build:prod": "astro build",
    "preview": "astro preview",
    "astro": "astro",

    "xplat:preview": "npm run preview --prefix docs/xplat",
    "xplat:dev": "npm run dev --prefix docs/xplat",
    "xplat:dev:angular": "npm run dev:angular --prefix docs/xplat",
    "xplat:dev:react": "npm run dev:react --prefix docs/xplat",
    "xplat:dev:webcomponents": "npm run dev:webcomponents --prefix docs/xplat",
    "xplat:dev:blazor": "npm run dev:blazor --prefix docs/xplat",
    "xplat:dev:angular:jp": "npm run dev:angular:jp --prefix docs/xplat",
    "xplat:dev:react:jp": "npm run dev:react:jp --prefix docs/xplat",
    "xplat:dev:webcomponents:jp": "npm run dev:webcomponents:jp --prefix docs/xplat",
    "xplat:dev:blazor:jp": "npm run dev:blazor:jp --prefix docs/xplat",

    "xplat:build:angular": "npm run build:angular --prefix docs/xplat",
    "xplat:build:react": "npm run build:react --prefix docs/xplat",
    "xplat:build:webcomponents": "npm run build:webcomponents --prefix docs/xplat",
    "xplat:build:blazor": "npm run build:blazor --prefix docs/xplat",
    "xplat:build:angular:jp": "npm run build:angular:jp --prefix docs/xplat",
    "xplat:build:react:jp": "npm run build:react:jp --prefix docs/xplat",
    "xplat:build:webcomponents:jp": "npm run build:webcomponents:jp --prefix docs/xplat",
    "xplat:build:blazor:jp": "npm run build:blazor:jp --prefix docs/xplat",

    "xplat:build-staging:angular": "npm run build-staging:angular --prefix docs/xplat",
    "xplat:build-staging:react": "npm run build-staging:react --prefix docs/xplat",
    "xplat:build-staging:webcomponents": "npm run build-staging:webcomponents --prefix docs/xplat",
    "xplat:build-staging:blazor": "npm run build-staging:blazor --prefix docs/xplat",
    "xplat:build-staging:angular:jp": "npm run build-staging:angular:jp --prefix docs/xplat",
    "xplat:build-staging:react:jp": "npm run build-staging:react:jp --prefix docs/xplat",
    "xplat:build-staging:webcomponents:jp": "npm run build-staging:webcomponents:jp --prefix docs/xplat",
    "xplat:build-staging:blazor:jp": "npm run build-staging:blazor:jp --prefix docs/xplat",

    "xplat:build-production:angular": "npm run build-production:angular --prefix docs/xplat",
    "xplat:build-production:react": "npm run build-production:react --prefix docs/xplat",
    "xplat:build-production:webcomponents": "npm run build-production:webcomponents --prefix docs/xplat",
    "xplat:build-production:blazor": "npm run build-production:blazor --prefix docs/xplat",
    "xplat:build-production:angular:jp": "npm run build-production:angular:jp --prefix docs/xplat",
    "xplat:build-production:react:jp": "npm run build-production:react:jp --prefix docs/xplat",
    "xplat:build-production:webcomponents:jp": "npm run build-production:webcomponents:jp --prefix docs/xplat",
    "xplat:build-production:blazor:jp": "npm run build-production:blazor:jp --prefix docs/xplat"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.0.1"
  },
  "devDependencies": {
    "@astrojs/starlight": ">=0.38",
    "@astrojs/ts-plugin": "^1.3.0",
    "igniteui-theming": "^25.0.2",
    "sass-embedded": "^1.98.0",
    "@types/jsdom": "^28.0.1",
    "astro": ">=6",
    "cross-env": "^10.1.0",
    "starlight-llms-txt": ">=0.8",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "@astrojs/starlight": ">=0.38",
    "astro": ">=6",
    "starlight-llms-txt": ">=0.8"
  },
  "engines": {
    "node": ">=18.17.1"
  }
}
