{
  "name": "docs-template",
  "type": "module",
  "version": "0.1.0",
  "description": "A basic Astro template for documentation sites",
  "scripts": {
    "dev": "astro dev",
    "dev:angular": "cross-env SOURCE_KEY=docfx DOCS_SOURCE_PATH=../igniteui-docfx astro dev",
    "dev:xplat": "cross-env SOURCE_KEY=xplat DOCS_SOURCE_PATH=../igniteui-xplat-docs astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.38.1",
    "astro": "^6.0.5",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@astrojs/ts-plugin": "^1.3.0",
    "cross-env": "^10.1.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.17.1"
  }
}
