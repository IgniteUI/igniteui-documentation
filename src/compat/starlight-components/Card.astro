---
interface Props {
  title: string;
  icon?: string;
}
const { title, icon } = Astro.props;
---
<article class="sl-card">
  {icon && <span class="sl-card-icon" aria-hidden="true">{icon}</span>}
  <h3 class="sl-card-title">{title}</h3>
  <div class="sl-card-body"><slot /></div>
</article>

<style>
  .sl-card {
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.5rem;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .sl-card-icon { font-size: 1.5rem; }
  .sl-card-title { margin: 0; font-size: 1rem; }
  .sl-card-body { font-size: 0.875rem; color: var(--sl-color-gray-3); }
</style>
