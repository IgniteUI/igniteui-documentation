---
interface Props {
  type?: 'note' | 'tip' | 'caution' | 'danger';
  title?: string;
}

const { type = 'note', title } = Astro.props;

const labels: Record<string, string> = {
  note: title ?? 'Note',
  tip: title ?? 'Tip',
  caution: title ?? 'Caution',
  danger: title ?? 'Danger',
};
---

<aside class={`aside aside--${type}`} aria-label={labels[type]}>
  <p class="aside-title" aria-hidden="true">{labels[type]}</p>
  <section class="aside-content">
    <slot />
  </section>
</aside>

<style>
  .aside {
    --aside-color: hsl(234, 90%, 60%);
    border-inline-start: 0.25rem solid var(--aside-color);
    padding: 1rem 1.25rem;
    background-color: color-mix(in srgb, var(--aside-color) 8%, transparent);
    border-radius: 0 0.375rem 0.375rem 0;
    margin: 1.5rem 0;
  }
  .aside--note { --aside-color: hsl(234, 90%, 60%); }
  .aside--tip  { --aside-color: hsl(134, 70%, 38%); }
  .aside--caution { --aside-color: hsl(40, 90%, 45%); }
  .aside--danger  { --aside-color: hsl(0, 85%, 52%); }

  .aside-title {
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--aside-color);
    margin: 0 0 0.5rem;
  }
  .aside-content > :first-child { margin-top: 0; }
  .aside-content > :last-child  { margin-bottom: 0; }
</style>
