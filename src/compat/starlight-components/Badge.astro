---
interface Props {
  text: string;
  variant?: 'note' | 'danger' | 'success' | 'caution' | 'tip' | 'default';
  size?: 'small' | 'medium' | 'large';
}
const { text, variant = 'default', size = 'small' } = Astro.props;
---
<span class={`sl-badge sl-badge--${variant} sl-badge--${size}`}>{text}</span>

<style>
  .sl-badge {
    display: inline-flex;
    align-items: center;
    border-radius: 0.25rem;
    padding: 0.125rem 0.375rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid currentColor;
  }
  .sl-badge--default { color: var(--sl-color-gray-3); }
  .sl-badge--note    { color: hsl(234, 90%, 60%); }
  .sl-badge--tip     { color: hsl(134, 70%, 38%); }
  .sl-badge--success { color: hsl(134, 70%, 38%); }
  .sl-badge--caution { color: hsl(40, 90%, 45%); }
  .sl-badge--danger  { color: hsl(0, 85%, 52%); }
</style>
