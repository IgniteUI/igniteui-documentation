---
interface Props {
  stagger?: boolean;
}
const { stagger = false } = Astro.props;
---
<div class={`sl-card-grid${stagger ? ' sl-card-grid--stagger' : ''}`}>
  <slot />
</div>

<style>
  .sl-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: 1rem;
    margin: 1.5rem 0;
  }
</style>
