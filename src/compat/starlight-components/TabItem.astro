---
interface Props {
  label: string;
}
const { label } = Astro.props;
---
<!-- Button rendered by Tabs.astro script; panel rendered here -->
<button role="tab" aria-selected="false" tabindex="-1" class="sl-tab-btn">{label}</button>
<div role="tabpanel" class="sl-tab-panel" hidden>
  <slot />
</div>

<style>
  .sl-tab-btn {
    padding: 0.5rem 1rem;
    border: none;
    border-bottom: 2px solid transparent;
    background: transparent;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--sl-color-gray-3);
  }
  .sl-tab-btn[aria-selected='true'] {
    color: var(--sl-color-accent);
    border-bottom-color: var(--sl-color-accent);
  }
  .sl-tab-panel {
    padding: 1rem 0;
  }
</style>
