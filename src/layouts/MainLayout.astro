---
import { ClientRouter } from 'astro:transitions';
import GlobalNavBar from '../components/GlobalNavBar.astro';
import GlobalFooter from '../components/GlobalFooter.astro';
import DocsSubHeader from '../components/DocsSubHeader.astro';
import MobileSidebarToggle from '../components/MobileSidebarToggle.astro';
import { widgetScriptSrc, platform as virtualPlatform } from 'virtual:docs-template/nav-html';
import { title as siteTitle, headEntries } from 'virtual:docs-template/site-meta';
import '../styles/ig-theme.scss';
import '../styles/custom.css';

export interface Props {
  title?: string;
  description?: string | null;
  keywords?: string | null;
  hasSidebar?: boolean;
  /** Slug of the current page; used to compute breadcrumbs in the subheader. */
  currentSlug?: string;
}

const { title, description, keywords, hasSidebar = true, currentSlug = '' } = Astro.props;
const navTheme = (virtualPlatform ?? import.meta.env.VITE_NAV_THEME ?? 'igniteui') as string;
const showGlobalNav = navTheme !== 'none';
const pageTitle = title ? `${title} | ${siteTitle}` : siteTitle;

type HeadEntry = { tag: string; attrs?: Record<string, string | boolean | undefined>; content?: string };
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  {description && <meta name="description" content={description} />}
  {keywords && <meta name="keywords" content={keywords} />}
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  {widgetScriptSrc && <script is:inline src={widgetScriptSrc} async></script>}
  {(headEntries as HeadEntry[]).map(({ tag: Tag, attrs = {}, content }) =>
    content ? <Tag {...attrs} set:html={content} /> : <Tag {...attrs} />
  )}
  <slot name="head" />
  <ClientRouter />
  <script is:inline>
    // Force light theme on load and after every View Transitions swap
    try { localStorage.setItem('starlight-theme', 'light'); } catch (_) {}
    document.documentElement.setAttribute('data-theme', 'light');
    document.addEventListener('astro:after-swap', function () {
      document.documentElement.setAttribute('data-theme', 'light');
    });

    // Preserve dynamically-injected <style> tags across View Transitions
    var _styleIndex = 0;
    function tagStyle(style) {
      var isAstroStyle = Array.from(style.attributes).some(function (a) { return a.name.startsWith('data-astro'); });
      if (!isAstroStyle && !style.hasAttribute('data-vt-preserved')) {
        style.setAttribute('data-vt-preserved', String(++_styleIndex));
      }
    }
    document.head.querySelectorAll('style').forEach(tagStyle);
    new MutationObserver(function (mutations) {
      mutations.forEach(function (m) {
        m.addedNodes.forEach(function (node) {
          if (node instanceof HTMLStyleElement) tagStyle(node);
        });
      });
    }).observe(document.head, { childList: true });
    document.addEventListener('astro:before-swap', function (e) {
      document.head.querySelectorAll('style[data-vt-preserved]').forEach(function (style) {
        var id = style.getAttribute('data-vt-preserved');
        if (!e.newDocument.head.querySelector('style[data-vt-preserved="' + id + '"]')) {
          e.newDocument.head.appendChild(style.cloneNode(true));
        }
      });
    });
  </script>
</head>
<body>
  {showGlobalNav && <GlobalNavBar />}
  <div style={`--docs-global-nav-height: ${showGlobalNav ? '86px' : '0px'}`}>
    <DocsSubHeader pageTitle={title} currentSlug={currentSlug} />
  </div>
  <div class="page">
    {hasSidebar && (
      <nav class="sidebar print:hidden" aria-label="Documentation navigation">
        <MobileSidebarToggle />
        <div class="sidebar-pane">
          <div class="sidebar-content">
            <slot name="sidebar" />
          </div>
        </div>
      </nav>
    )}
    <div class="main-frame">
      <slot />
    </div>
    <aside class="toc-sidebar print:hidden" aria-label="Table of contents">
      <slot name="toc" />
    </aside>
  </div>
  <GlobalFooter />
  <script>
    function updateSidebarBottom() {
      const footer = document.querySelector<HTMLElement>('.page + *');
      if (!footer) return;
      const visible = Math.max(0, window.innerHeight - footer.getBoundingClientRect().top);
      document.documentElement.style.setProperty('--sl-sidebar-bottom', `${visible}px`);
    }
    document.addEventListener('scroll', updateSidebarBottom, { passive: true });
    window.addEventListener('resize', updateSidebarBottom);
    document.addEventListener('astro:page-load', updateSidebarBottom);
    updateSidebarBottom();
  </script>
</body>
</html>

<style is:global>
  /* ── Design tokens — replaces Starlight's built-in CSS custom properties ── */
  :root {
    /* Sidebar */
    --sl-sidebar-width: 18.75rem;
    --sl-sidebar-pad-x: 1rem;
    --sl-content-inline-start: var(--sl-sidebar-width);
    /* Z-index */
    --sl-z-index-navbar: 10;
    --sl-z-index-menu: 9;
    /* Nav */
    --sl-nav-gap: 1rem;
    --sl-menu-button-size: 2rem;
    /* Typography */
    --sl-text-xs: 0.75rem;
    --sl-text-sm: 0.875rem;
    --sl-text-base: 1rem;
    --sl-text-lg: 1.125rem;
    --sl-text-xl: 1.25rem;
    --sl-text-2xl: 1.5rem;
    --sl-text-3xl: 1.875rem;
    --sl-text-4xl: 2.25rem;
    /* Light-mode colors */
    --sl-color-white: hsl(0, 0%, 100%);
    --sl-color-gray-1: hsl(240, 6%, 90%);
    --sl-color-gray-2: hsl(240, 5%, 74%);
    --sl-color-gray-3: hsl(240, 5%, 58%);
    --sl-color-gray-4: hsl(240, 4%, 46%);
    --sl-color-gray-5: hsl(240, 5%, 35%);
    --sl-color-gray-6: hsl(240, 10%, 26%);
    --sl-color-black: hsl(240, 16%, 11%);
    --sl-color-bg: hsl(0, 0%, 100%);
    --sl-color-bg-nav: hsl(0, 0%, 100%);
    --sl-color-bg-sidebar: hsl(224, 10%, 97%);
    --sl-color-bg-inline-code: hsl(219, 13%, 93%);
    --sl-color-hairline-light: hsl(240, 6%, 90%);
    --sl-color-hairline: hsl(240, 9%, 85%);
    --sl-color-hairline-shade: hsl(240, 6%, 78%);
    --sl-color-text: hsl(240, 16%, 11%);
    --sl-color-text-accent: hsl(234, 90%, 60%);
    --sl-color-accent: hsl(234, 90%, 60%);
    --sl-color-accent-low: hsl(234, 88%, 90%);
    --sl-color-accent-high: hsl(234, 90%, 45%);
    /* Shadows */
    --sl-shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.1);
    --sl-shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1);
    --sl-shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);
  }

  *, *::before, *::after {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    font-size: var(--sl-text-base);
    color: var(--sl-color-text);
    background-color: var(--sl-color-bg);
    line-height: 1.625;
  }

  a {
    color: var(--sl-color-text-accent);
    text-decoration: none;
  }
  a:hover { text-decoration: underline; }

  /* ── Page shell ──────────────────────────────────────────────────────────── */

  .page {
    min-height: 100vh;
    padding-block-start: var(--sl-nav-height);
  }

  /* ── Sidebar ─────────────────────────────────────────────────────────────── */

  /*
   * Mobile: sidebar-pane is a fixed full-width overlay controlled by the
   * MobileSidebarToggle button (aria-expanded sibling + body attribute).
   * Desktop: sidebar-pane is a fixed left rail, always visible.
   */

  .sidebar-pane {
    visibility: var(--sl-sidebar-visibility, hidden);
    position: fixed;
    z-index: var(--sl-z-index-menu);
    inset-block: calc(var(--sl-nav-height) + var(--docs-mobile-toggle-height)) 0;
    inset-inline-start: 0;
    width: 100%;
    background-color: var(--sl-color-bg-sidebar);
    /* The inner .sidebar-scroll owns vertical scrolling so the filter input
       (rendered above it) stays pinned and always visible. */
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* Show sidebar when the toggle button (preceding sibling) is expanded */
  [aria-expanded='true'] ~ .sidebar-pane {
    --sl-sidebar-visibility: visible;
  }

  .sidebar-content {
    flex: 1;
    min-height: 0;
    padding: 1rem var(--sl-sidebar-pad-x) 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (min-width: 50rem) {
    .sidebar-content::after {
      content: '';
      padding-bottom: 1px;
    }

    .sidebar-pane {
      --sl-sidebar-visibility: visible;
      width: var(--sl-sidebar-width);
      background-color: var(--sl-color-bg-sidebar);
      border-inline-end: 1px solid var(--sl-color-hairline-shade);
      inset-block-start: var(--sl-nav-height);
      inset-block-end: var(--sl-sidebar-bottom, 0px);
    }
  }

  /* ── Main frame ──────────────────────────────────────────────────────────── */

  .main-frame {
    padding-block-start: var(--docs-mobile-toggle-height);
  }

  @media (min-width: 50rem) {
    .main-frame {
      padding-block-start: 0;
      padding-inline-start: var(--sl-content-inline-start, 0);
    }
  }
  /* ── Content prose ───────────────────────────────────────────────────────── */

  .sl-markdown-content {
    max-width: 50rem;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .sl-markdown-content h1,
  .sl-markdown-content h2,
  .sl-markdown-content h3,
  .sl-markdown-content h4,
  .sl-markdown-content h5,
  .sl-markdown-content h6 {
    scroll-margin-top: calc(var(--sl-nav-height) + 1.5rem);
  }

  .sl-markdown-content h1 { font-size: var(--sl-text-4xl); margin-block: 0 1rem; }
  .sl-markdown-content h2 { font-size: var(--sl-text-2xl); margin-block: 2rem 0.75rem; }
  .sl-markdown-content h3 { font-size: var(--sl-text-xl);  margin-block: 1.5rem 0.5rem; }
  .sl-markdown-content p  { margin-block: 0.75rem; }
  .sl-markdown-content pre {
    background: var(--sl-color-bg-sidebar);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.375rem;
    padding: 1rem;
    overflow-x: auto;
  }
  .sl-markdown-content code {
    background: var(--sl-color-bg-inline-code);
    border-radius: 0.25rem;
    padding: 0.125rem 0.25rem;
    font-size: 0.875em;
  }
  .sl-markdown-content pre code {
    background: transparent;
    padding: 0;
  }

  /* ── Utility ─────────────────────────────────────────────────────────────── */

  @media print {
    .print\:hidden { display: none !important; }
  }

</style>
