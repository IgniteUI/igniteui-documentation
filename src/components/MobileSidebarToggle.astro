---
/**
 * MobileSidebarToggle
 *
 * Mobile-only fixed button that toggles the sidebar overlay.
 * Props:
 *   label  – visible button text (e.g. group name). Default: 'Components List'.
 */
interface Props {
  label?: string;
}
const { label = "Components List" } = Astro.props;
---

<button
  id="mobile-sidebar-toggle"
  class="mobile-sidebar-toggle"
  aria-expanded="false"
  aria-controls="starlight__sidebar"
  aria-label={`Toggle ${label} sidebar`}
>
  <span class="trigger-label">{label}</span>
  <svg
    class="mobile-sidebar-toggle_chevron"
    xmlns="http://www.w3.org/2000/svg"
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <polyline points="6 9 12 15 18 9"></polyline>
  </svg>
</button>

<script>
  document.addEventListener("click", (e) => {
    const trigger = (e.target as Element).closest<HTMLElement>("#mobile-sidebar-toggle");
    if (!trigger) return;
    const expanded = trigger.getAttribute("aria-expanded") === "true";
    trigger.setAttribute("aria-expanded", String(!expanded));
    document.body.toggleAttribute("data-mobile-menu-expanded", !expanded);
  });

  document.addEventListener("keyup", (e) => {
    if (e.key !== "Escape") return;
    const trigger = document.getElementById("mobile-sidebar-toggle");
    if (trigger && trigger.getAttribute("aria-expanded") === "true") {
      trigger.setAttribute("aria-expanded", "false");
      document.body.removeAttribute("data-mobile-menu-expanded");
      trigger.focus();
    }
  });

  document.addEventListener("astro:page-load", () => {
    const trigger = document.getElementById("mobile-sidebar-toggle");
    if (trigger) trigger.setAttribute("aria-expanded", "false");
    document.body.removeAttribute("data-mobile-menu-expanded");
  });
</script>

<style is:global>
  @layer starlight.core {
    .mobile-sidebar-toggle {
      position: fixed;
      top: var(--sl-nav-height);
      inset-inline-start: 0;
      z-index: calc(var(--sl-z-index-navbar) - 1);
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      height: var(--docs-mobile-toggle-height);
      padding: 0 var(--sl-sidebar-pad-x, 1rem);
      background: var(--sl-color-bg-sidebar);
      border: none;
      border-bottom: 1px solid var(--sl-color-hairline-shade);
      cursor: pointer;
      color: var(--sl-color-text-accent);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .mobile-sidebar-toggle_chevron {
      flex-shrink: 0;
      transition: transform 0.2s ease;
    }

    .mobile-sidebar-toggle[aria-expanded="true"]
      .mobile-sidebar-toggle_chevron {
      transform: rotate(180deg);
    }

    [data-mobile-menu-expanded] {
      overflow: hidden;
    }

    @media (min-width: 50rem) {
      .mobile-sidebar-toggle {
        display: none;
      }

      [data-mobile-menu-expanded] {
        overflow: auto;
      }
    }
  }
</style>
