---
/**
 * ThemingWidget
 *
 * Renders the `<igniteui-theming-widget>` web component. Mirrors the
 * behaviour from igniteui-docfx-template:
 *   template/partials/themeselect*.tmpl.partial
 *   src/app/handlers/theming.ts
 *
 * Behaviour:
 *   - `themeApiUrl` and `widgetVersion` are resolved from environment.json at
 *     build time via the `virtual:docs-template/nav-html` virtual module
 *     (same step as the header/footer prefetch in siteMetaIntegration).
 *   - Renders nothing when `themeApiUrl` is unavailable.
 *   - The widget container starts hidden and is revealed client-side only
 *     when at least one themeable `<iframe>` is found on the page.
 *   - Forwards `themeChange` events from the widget to every themeable frame
 *     via `postMessage`.
 *   - Re-initialises on Astro View-Transitions navigation (`astro:page-load`).
 *
 * Props:
 *   language – locale passed to the web component. Defaults to 'en'.
 */

import {
  themeApiUrl,
  widgetVersion,
} from 'virtual:docs-template/nav-html';

interface Props {
  language?: 'en' | 'ja' | 'kr';
}

const { language = 'en' } = Astro.props;

// CDN script URL for the web component bundle.
const scriptSrc = `https://cdn-na.infragistics.com/igniteui/theming-widget/${widgetVersion}/igniteui-theming-widget.js`;

// Only add the `language` attribute for non-English locales.
const lang = language !== 'en' ? language : undefined;
---

{themeApiUrl && (
  <>
    {/* Preload hint — browser starts the CDN download as early as possible. */}
    <link rel="preload" href={scriptSrc} as="script" />
    {/* Load the custom-element bundle asynchronously — no render blocking. */}
    <script is:inline src={scriptSrc} async></script>

    {/*
      Widget container — always visible when themeApiUrl is set.
      The client script below wires up theme→iframe forwarding.
    */}
    <div id="theming-widget-container" class="theming-widget-container">
      {lang
        ? <igniteui-theming-widget theme-url={themeApiUrl} language={lang} />
        : <igniteui-theming-widget theme-url={themeApiUrl} />
      }
    </div>
  </>
)}

{/*
  Init script — always bundled by Astro but self-guards by checking the
  container element. When themeApiUrl was empty at build time the container
  is absent, so this script becomes a no-op.
*/}
<script>
  // Module-level cleanup reference so re-init on View Transitions tears down
  // the previous observer + event listener before creating new ones.
  let _cleanup: (() => void) | null = null;

  function initThemingWidget() {
    if (_cleanup) { _cleanup(); _cleanup = null; }

    const container = document.getElementById('theming-widget-container');
    if (!container) return;

    // Must query the widget element directly — themeChange is likely non-bubbling,
    // so attaching to the parent container div would miss it.
    const widget = container.querySelector('igniteui-theming-widget') as
      (HTMLElement & { theme?: { globalTheme: string } }) | null;
    if (!widget) return;

    // ── postMessage helper ───────────────────────────────────────────────────
    // Uses the iframe's origin (not the full URL path) as targetOrigin.
    function postToIframe(iframe: HTMLIFrameElement, themeStyle: string) {
      const src = iframe.src;
      if (!src || src.startsWith('about:') || src.startsWith('javascript:')) return;
      try {
        const targetOrigin = new URL(src).origin;
        iframe.contentWindow?.postMessage(
          { themeStyle, origin: location.origin, themeName: widget?.theme?.globalTheme ?? '' },
          targetOrigin,
        );
      } catch { /* cross-origin or invalid URL — ignore */ }
    }

    // ── Replay theme into a newly loaded iframe ──────────────────────────────
    // Mirrors docfx's onSampleIframeContentLoaded: when an iframe finishes
    // loading we immediately push the persisted themeStyle into it so samples
    // that loaded after a theme was already selected pick it up.
    function onIframeLoad(e: Event) {
      const iframe = e.target as HTMLIFrameElement;
      if (iframe.classList.contains('no-theming')) return;
      const stored = sessionStorage.getItem('themeStyle');
      if (stored) postToIframe(iframe, stored);
    }

    function attachLoadListener(node: Element) {
      if (node instanceof HTMLIFrameElement && !node.classList.contains('no-theming')) {
        node.addEventListener('load', onIframeLoad, { once: true });
      }
      node.querySelectorAll?.('iframe:not(.no-theming)').forEach(iframe => {
        (iframe as HTMLIFrameElement).addEventListener('load', onIframeLoad, { once: true });
      });
    }

    // Attach to iframes already in the DOM (e.g. first load, frame 0 queued immediately).
    document.querySelectorAll<HTMLIFrameElement>('iframe:not(.no-theming)')
      .forEach(iframe => iframe.addEventListener('load', onIframeLoad, { once: true }));

    // ── themeChange → broadcast to all loaded iframes ───────────────────────
    function onThemeChange(e: Event) {
      const themeStyle = (e as CustomEvent<string>).detail;
      sessionStorage.setItem('themeStyle', themeStyle);
      document.querySelectorAll<HTMLIFrameElement>('iframe:not(.no-theming)').forEach(iframe => {
        if (!iframe.src || iframe.src.startsWith('about:')) return;
        // Skip lazy iframes that haven't received a real src yet.
        if (iframe.classList.contains('lazyload') && !iframe.classList.contains('lazyloaded')) return;
        postToIframe(iframe, themeStyle);
      });
    }

    widget.addEventListener('themeChange', onThemeChange);

    // ── MutationObserver: watch for iframes injected after init ──────────────
    const observer = new MutationObserver((mutations) => {
      for (const mut of mutations) {
        mut.addedNodes.forEach(node => {
          if (node instanceof Element) attachLoadListener(node);
        });
      }
    });
    observer.observe(document.body, { childList: true, subtree: true });

    _cleanup = () => {
      observer.disconnect();
      widget.removeEventListener('themeChange', onThemeChange);
    };
  }

  // Run on initial load and after every View-Transitions navigation.
  document.addEventListener('astro:page-load', initThemingWidget);
  initThemingWidget();
</script>

<style>
  .theming-widget-container {
    display: contents;
  }
</style>
