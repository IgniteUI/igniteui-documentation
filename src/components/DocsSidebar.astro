---
import { sidebar as sidebarData } from 'virtual:docs-template/site-meta';

interface Props {
  currentSlug?: string;
}

const { currentSlug = '' } = Astro.props;
const normalizedCurrent = currentSlug.replace(/^\/|\/$/g, '');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// ── Types (mirrors sidebar.ts) ──────────────────────────────────────────────

type SidebarBadge = { text: string; variant: string };
type SidebarLink = {
  label: string;
  slug: string;
  badge?: SidebarBadge;
  attrs?: Record<string, string | number | boolean | undefined>;
};
type SidebarGroup = {
  label: string;
  items: SidebarEntry[];
  collapsed?: boolean;
};
type SidebarEntry = SidebarLink | SidebarGroup;

function isGroup(e: SidebarEntry): e is SidebarGroup {
  return 'items' in e;
}

function isActive(slug: string): boolean {
  return normalizedCurrent === slug.replace(/^\/|\/$/g, '');
}

function hasActive(items: SidebarEntry[]): boolean {
  return items.some(item =>
    isGroup(item) ? hasActive(item.items) : isActive(item.slug),
  );
}

function esc(s: string): string {
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

function badgeHtml(badge: SidebarBadge): string {
  return `<span class="sl-badge ${esc(badge.variant)}">${esc(badge.text)}</span>`;
}

function extraAttrs(attrs?: SidebarLink['attrs']): string {
  if (!attrs) return '';
  return Object.entries(attrs)
    .filter(([, v]) => v !== undefined && v !== false)
    .map(([k, v]) => (v === true ? esc(k) : `${esc(k)}="${esc(String(v))}"`))
    .join(' ');
}

function renderItem(item: SidebarEntry): string {
  if (isGroup(item)) {
    const open = !item.collapsed || hasActive(item.items);
    const children = item.items.map(renderItem).join('');
    return `
<li class="sidebar-group">
  <details${open ? ' open' : ''}>
    <summary class="group-label"><span class="group-label-text">${esc(item.label)}</span></summary>
    <ul class="sidebar-group-items">${children}</ul>
  </details>
</li>`;
  }

  const active = isActive(item.slug);
  const badge = item.badge ? badgeHtml(item.badge) : '';
  const extra = extraAttrs(item.attrs);
  return `
<li>
  <a href="${base}/${esc(item.slug)}/" aria-current="${active ? 'page' : 'false'}"${extra ? ' ' + extra : ''}>${esc(item.label)}${badge}</a>
</li>`;
}

const html = (sidebarData as SidebarEntry[]).map(renderItem).join('');
---

<div class="sidebar-filter" id="docs-sidebar">
  <ul class="sidebar-list">
    <Fragment set:html={html} />
  </ul>
</div>

<style>
  .sidebar-list,
  .sidebar-group-items {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sidebar-group {
    margin-block: 0.25rem;
  }

  details summary {
    cursor: pointer;
    list-style: none;
    padding: 0.25rem 0;
  }
  details summary::-webkit-details-marker { display: none; }

  .group-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--sl-text-xs, 0.75rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--sl-color-gray-3, #888);
    padding: 0.5rem 0 0.25rem;
  }

  .group-label-text {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .sidebar-group-items {
    padding-inline-start: 0.75rem;
    border-inline-start: 1px solid var(--sl-color-hairline, #e2e4e9);
    margin-inline-start: 0.25rem;
  }

  /* Links */
  :global(.sidebar-list a),
  :global(.sidebar-group-items a) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.5rem;
    border-radius: 0.25rem;
    font-size: var(--sl-text-sm, 0.875rem);
    color: var(--sl-color-text, inherit);
    text-decoration: none;
    line-height: 1.4;
  }

  :global(.sidebar-list a:hover),
  :global(.sidebar-group-items a:hover) {
    background: color-mix(in srgb, var(--sl-color-accent) 8%, transparent);
    color: var(--sl-color-accent, #3b82f6);
    text-decoration: none;
  }

  :global(.sidebar-list a[aria-current='page']),
  :global(.sidebar-group-items a[aria-current='page']) {
    background: color-mix(in srgb, var(--sl-color-accent) 12%, transparent);
    color: var(--sl-color-accent, #3b82f6);
    font-weight: 600;
  }

  /* Badges */
  :global(.sl-badge) {
    display: inline-flex;
    align-items: center;
    border-radius: 0.25rem;
    padding: 0.1rem 0.35rem;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid currentColor;
    margin-inline-start: auto;
    flex-shrink: 0;
  }
  :global(.sl-badge.default) { color: var(--sl-color-gray-3); }
  :global(.sl-badge.note)    { color: hsl(234, 90%, 60%); }
  :global(.sl-badge.tip)     { color: hsl(134, 70%, 38%); }
  :global(.sl-badge.success) { color: hsl(134, 70%, 38%); }
  :global(.sl-badge.caution) { color: hsl(40, 90%, 45%); }
  :global(.sl-badge.danger)  { color: hsl(0, 85%, 52%); }
</style>
