---
// Overrides @astrojs/starlight/components/Sidebar.astro
import SidebarPersister from '@astrojs/starlight/components/SidebarPersister.astro';
import SidebarSublist from '@astrojs/starlight/components/SidebarSublist.astro';
import SidebarFilterInput from './SidebarFilterInput.astro';

const { sidebar } = Astro.locals.starlightRoute;
---

<sidebar-filter data-no-results="No topics match">
  <SidebarFilterInput />

  <div id="starlight__sidebar" class="sidebar-scroll">
    <SidebarPersister>
      <SidebarSublist sublist={sidebar} />
    </SidebarPersister>
  </div>
</sidebar-filter>

<script src="./sidebar-filter"></script>

<script>
  function updateSidebarBottom() {
    const footerContainer = document.querySelector('.page > *:last-child');
    if (!footerContainer) return;
    const visibleHeight = Math.max(0, window.innerHeight - footerContainer.getBoundingClientRect().top);
    document.documentElement.style.setProperty('--sl-sidebar-bottom', `${visibleHeight}px`);
  }

  document.addEventListener('scroll', updateSidebarBottom, { passive: true });
  window.addEventListener('resize', updateSidebarBottom);
  document.addEventListener('astro:page-load', updateSidebarBottom);
  updateSidebarBottom();
</script>

<style>
  @layer starlight.user {
    sidebar-filter {
      display: flex;
      flex-direction: column;
      flex: 1;
      min-height: 0;
    }

    /* The list area scrolls independently of the filter input */
    sidebar-filter .sidebar-scroll {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      /* Pull to the full pane width so the scrollbar sits flush with the border */
      margin-inline-end: calc(-1 * var(--sl-sidebar-pad-x, 1rem));
      padding-inline-end: var(--sl-sidebar-pad-x, 1rem);
    }

    /* Ensure filtered-out items are fully removed from layout */
    sidebar-filter li[hidden] {
      display: none !important;
    }

    /* Opt the sidebar out of Astro's page cross-fade so the caret states
       never appear in a View Transitions screenshot mid-animation. */
    sidebar-filter {
      view-transition-name: docs-sidebar;
    }
    ::view-transition-old(docs-sidebar),
    ::view-transition-new(docs-sidebar) {
      animation: none;
    }
  }
</style>
