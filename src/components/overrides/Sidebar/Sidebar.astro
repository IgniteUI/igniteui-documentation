---
// Overrides @astrojs/starlight/components/Sidebar.astro
import SidebarPersister from '@astrojs/starlight/components/SidebarPersister.astro';
import SidebarSublist from '@astrojs/starlight/components/SidebarSublist.astro';
import SidebarFilterInput from './SidebarFilterInput.astro';

const { sidebar } = Astro.locals.starlightRoute;
---

<sidebar-filter data-no-results="No topics match">
  <SidebarFilterInput />

  <div class="sidebar-scroll">
    <SidebarPersister>
      <SidebarSublist sublist={sidebar} />
    </SidebarPersister>
  </div>
</sidebar-filter>

<script src="./sidebar-filter"></script>

<style>
  @layer starlight.user {
    sidebar-filter {
      display: flex;
      flex-direction: column;
      flex: 1;
      min-height: 0;
    }

    /* The list area scrolls independently of the filter input */
    sidebar-filter .sidebar-scroll {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      /* Pull to the full pane width so the scrollbar sits flush with the border */
      margin-inline-end: calc(-1 * var(--sl-sidebar-pad-x, 1rem));
      padding-inline-end: var(--sl-sidebar-pad-x, 1rem);
    }

    /* Ensure filtered-out items are fully removed from layout */
    sidebar-filter li[hidden] {
      display: none !important;
    }
  }
</style>
