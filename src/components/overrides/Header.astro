---
/**
 * Header component override
 *
 * Wraps Starlight's default Header to add:
 *   1. The Infragistics global navigation bar (GlobalNavBar) above the
 *      Starlight doc-header. Equivalent to the product-theme dispatcher in
 *      template/partials/navbar.tmpl.partial.
 *   2. (Optional) PlatformSwitcher in the Starlight header for multi-platform
 *      IgniteUI documentation.
 *
 * Configuration is driven by `astro.config.mjs` components override or by
 * setting the theme/lang/platform via environment/site config.
 *
 * To enable GlobalNavBar:
 *   - Set VITE_NAV_THEME env var (igniteui | appbuilder | reveal | slingshot)
 *   - Set VITE_NAV_LANG env var (en | ja | kr)
 *   - Or hardcode the props below for a single-product deployment.
 */
import type { Props } from '@astrojs/starlight/props';
import GlobalNavBar from '@/components/GlobalNavBar.astro';
import { platform as virtualPlatform, navLang as virtualNavLang } from 'virtual:docs-template/nav-html';

// Virtual module `platform` (set via siteMetaIntegration) takes precedence;
// VITE_NAV_THEME env var is kept as a deployment-time fallback.
const navTheme = (virtualPlatform ?? import.meta.env.VITE_NAV_THEME ?? 'igniteui') as
  'igniteui' | 'appbuilder' | 'reveal' | 'slingshot' | 'angular' | 'react' | 'blazor' | 'web-components';
const navLang = (virtualNavLang ?? import.meta.env.VITE_NAV_LANG ?? 'en') as 'en' | 'ja' | 'kr';

// Disable the global nav entirely when VITE_NAV_THEME is set to 'none'
const showGlobalNav = navTheme !== ('none' as string);
---

{showGlobalNav && <GlobalNavBar theme={navTheme} lang={navLang} />}