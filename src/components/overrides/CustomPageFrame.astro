---
/**
 * This is a custom PageFrame component that overrides the default Starlight PageFrame.
 * It is used to wrap the entire page content, including the header, sidebar, main content, and footer. It is
 * responsible for rendering the layout structure and applying the necessary styles for the page.
 *
 * Mobile:
 *   The sidebar is toggled via a mobile button. `MobileSidebarToggle` is
 *   rendered in the nav so it can be positioned below the header and toggle
 *   the sidebar overlay using `data-mobile-menu-expanded` on <body>.
 *
 * Desktop (≥ 50rem):
 *   Standard fixed sidebar on the inline-start edge; trigger is hidden.
 */
import GlobalFooter from "../GlobalFooter.astro";
import MobileSidebarToggle from "../MobileSidebarToggle.astro";

const { hasSidebar, entry } = Astro.locals.starlightRoute;
const groupLabel: string =
  ((entry?.data as Record<string, unknown>)?.groupMetaTitle as string) ||
  "Components List";
---

<div class="page sl-flex">
  <header class="header"><slot name="header" /></header>
  {
    hasSidebar && (
      <nav
        class="sidebar print:hidden"
        aria-label={Astro.locals.t("sidebarNav.accessibleLabel")}
      >
        <MobileSidebarToggle label={groupLabel} />
        <div class="sidebar-pane">
          <div class="sidebar-content sl-flex">
            <slot name="sidebar" />
          </div>
        </div>
      </nav>
    )
  }
  <div class="main-frame"><slot /></div>
  <GlobalFooter />
</div>

<style>
  @layer starlight.core {
    .page {
      flex-direction: column;
      min-height: 100vh;
    }

    .header {
      z-index: var(--sl-z-index-navbar);
      position: fixed;
      inset-inline-start: 0;
      inset-block-start: 0;
      width: 100%;
      height: var(--sl-nav-height);
      border-bottom: 1px solid var(--sl-color-hairline-shade);
      padding: var(--sl-nav-pad-y) var(--sl-nav-pad-x);
      padding-inline-end: var(--sl-nav-pad-x);
      background-color: var(--sl-color-bg-nav);
    }

    :global([data-has-sidebar]) .header {
      padding-inline-end: calc(
        var(--sl-nav-gap) + var(--sl-nav-pad-x) + var(--sl-menu-button-size)
      );
    }

    .sidebar-pane {
      visibility: var(--sl-sidebar-visibility, hidden);
      position: fixed;
      z-index: var(--sl-z-index-menu);
      inset-block: calc(var(--sl-nav-height) + var(--docs-mobile-toggle-height)) 0;
      inset-inline-start: 0;
      width: 100%;
      background-color: var(--sl-color-black);
      overflow-y: auto;
    }

    :global([aria-expanded="true"]) ~ .sidebar-pane {
      --sl-sidebar-visibility: visible;
    }

    .sidebar-content {
      height: 100%;
      min-height: max-content;
      padding: 1rem var(--sl-sidebar-pad-x) 0;
      flex-direction: column;
      gap: 1rem;
    }

    @media (min-width: 50rem) {
      .sidebar-content::after {
        content: "";
        padding-bottom: 1px;
      }
    }

    .main-frame {
      padding-top:  calc(var(--sl-nav-height) + var(--docs-mobile-toggle-height));
      padding-inline-start: var(--sl-content-inline-start);
    }

    @media (min-width: 50rem) {
      :global([data-has-sidebar]) .header {
        padding-inline-end: var(--sl-nav-pad-x);
      }
      .sidebar-pane {
        --sl-sidebar-visibility: visible;
        width: var(--sl-sidebar-width);
        background-color: var(--sl-color-bg-sidebar);
        border-inline-end: 1px solid var(--sl-color-hairline-shade);
        inset-block-start: var(--sl-nav-height);
      }
	  .main-frame {
		padding-top: var(--sl-nav-height);
	  }
    }
  }
</style>
