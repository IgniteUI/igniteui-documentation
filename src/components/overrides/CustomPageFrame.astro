---
/**
 * CustomPageFrame — Starlight PageFrame override.
 *
 * Mobile:
 *   The sidebar is an inline accordion. SidebarAccordionTrigger is rendered
 *   as a direct sibling of .sidebar-pane so the CSS selector
 *     .sidebar-accordion-trigger[aria-expanded='true'] ~ .sidebar-pane
 *   drives visibility without extra JS DOM traversal.
 *
 * Desktop (≥ 50rem):
 *   Standard fixed sidebar on the inline-start edge; trigger is hidden.
 */
import GlobalFooter from "../GlobalFooter.astro";
import SidebarAccordionTrigger from "../SidebarAccordionTrigger.astro";

const { hasSidebar, entry } = Astro.locals.starlightRoute;
const groupLabel: string =
  ((entry?.data as Record<string, unknown>)?.groupMetaTitle as string) ||
  "Components List";
---

<div class="page sl-flex">
  <header class="header"><slot name="header" /></header>
  {
    hasSidebar && (
      <nav
        class="sidebar print:hidden"
        aria-label={Astro.locals.t("sidebarNav.accessibleLabel")}
      >
        <SidebarAccordionTrigger label={groupLabel} />
        <div id="starlight__sidebar" class="sidebar-pane">
          <div class="sidebar-content sl-flex">
            <slot name="sidebar" />
          </div>
        </div>
      </nav>
    )
  }
  <div class="main-frame"><slot /></div>
  <GlobalFooter />
</div>

<style>
  @layer starlight.core {
    .page {
      flex-direction: column;
      min-height: 100vh;
      padding-top: var(--sl-nav-height);
    }

    .header {
      z-index: var(--sl-z-index-navbar);
      position: fixed;
      inset-inline-start: 0;
      inset-block-start: 0;
      width: 100%;
      height: var(--sl-nav-height);
      border-bottom: 1px solid var(--sl-color-hairline-shade);
      padding: var(--sl-nav-pad-y) var(--sl-nav-pad-x);
      background-color: var(--sl-color-bg-nav);
    }

    /* ── Sidebar pane: collapsed by default on mobile ── */
    .sidebar-pane {
      overflow: hidden;
      max-height: 0;
      transition: max-height 0.3s ease;
      background-color: var(--sl-color-bg-sidebar);
    }

    /* CSS sibling selector: trigger expands pane */
    :global(.sidebar-accordion-trigger[aria-expanded="true"]) ~ .sidebar-pane {
      max-height: 100svh;
      overflow-y: auto;
    }

    .sidebar-content {
      min-height: max-content;
      padding: 1rem var(--sl-sidebar-pad-x, 1rem) 1rem;
      flex-direction: column;
      gap: 1rem;
    }

    .main-frame {
      flex: 1;
      padding-inline-start: 0;
    }

    /* ── Desktop ── */
    @media (min-width: 50rem) {
      .page {
        padding-top: 0;
      }

      .sidebar {
        position: fixed;
        inset-block: var(--sl-nav-height) 0;
        inset-inline-start: 0;
        width: var(--sl-sidebar-width);
        overflow-y: auto;
        background-color: var(--sl-color-bg-sidebar);
        border-inline-end: 1px solid var(--sl-color-hairline-shade);
      }

      .sidebar-pane {
        max-height: none;
        overflow: visible;
        background-color: transparent;
      }

      .sidebar-content::after {
        content: "";
        padding-bottom: 1px;
      }

      .main-frame {
        padding-top: var(--sl-nav-height);
        padding-inline-start: var(--sl-content-inline-start);
      }
    }
  }
</style>
