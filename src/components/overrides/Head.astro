---
/**
 * Starlight Head component override.
 *
 * We fully own the following tags, filtering Starlight's versions out and
 * emitting our own directly from entry.data so we have complete control:
 *
 *   - <title> — Starlight appends " | {siteTitle}" unconditionally.
 *   - <meta name="description"> — Emitted by Starlight by default, but we control it.
 *   - <meta name="keywords">    — Starlight never emits this.
 *
 * Data flow:
 *   remark-docfx maps _description → description, _keywords → keywords
 *     → docsSchema captures both into entry.data
 */

type EntryData = {
    title: string;
    description: string;
    keywords: string;
};

const OWNED_TAGS = new Set(['title']);
const OWNED_ATTRS = new Set(['description', 'keywords']);

const { entry, head } = Astro.locals.starlightRoute;
const { title, description, keywords } = entry.data as EntryData;

// Strip tags we own from Starlight's head so nothing is duplicated.
const passthroughHead = head.filter((e) => {
    if (OWNED_TAGS.has(e.tag)) return false;
    const prop = (e.attrs as Record<string, string>).property ?? (e.attrs as Record<string, string>).name;
    if (prop && OWNED_ATTRS.has(prop)) return false;
    return true;
});
---

<title>{title.trim()}</title>
<meta name="description" content={description.trim()} />
<meta name="keywords" content={keywords.trim()} />
{passthroughHead.map(({ tag: Tag, attrs, content }) => (
    <Tag {...attrs} set:html={content} />
))}


