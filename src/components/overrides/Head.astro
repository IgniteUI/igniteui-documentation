---
/**
 * Starlight Head component override.
 *
 * We fully own the following tags, filtering Starlight's versions out and
 * emitting our own directly from entry.data so we have complete control:
 *
 *   tag/attr               why we own it
 *   ────────────────────   ────────────────────────────────────────────────
 *   <title>                Starlight appends " | {siteTitle}" unconditionally.
 *   description            Starlight emits it, but in case we want to change it
 *   keywords               Starlight never emits this; we add it.
 *
 * Everything else (canonical, og:title, og:description og:type, og:url, og:locale, og:site_name,
 * twitter:card, favicon, charset, viewport, generator …) is passed through
 * from Starlight's starlightRoute.head unchanged.
 *
 * ClientRouter enables Astro View Transitions (client-side navigation).
 * This causes Astro to fire `astro:page-load` after each navigation, which
 * lets sidebar filter state and code-view widgets re-initialize without a
 * full page reload.
 */

import { ClientRouter } from 'astro:transitions';
import { widgetScriptSrc } from 'virtual:docs-template/nav-html';

type EntryData = {
    title: string;
    description?: string | null;
    keywords?: string | null;
};

const { entry, head } = Astro.locals.starlightRoute;
const { title, description, keywords } = entry.data as EntryData;

// Only filter Starlight's description tag when we have our own value to
// replace it with; otherwise let the passthrough entry stand.
const passthroughHead = head.filter(({ tag, attrs }) => {
    if (tag === 'title') return false;
    if (description) {
        const safeAttrs = (attrs ?? {}) as Record<string, string>;
        const attr = safeAttrs.property ?? safeAttrs.name;
        if (attr === 'description') return false;
    }
    return true;
});
---

{/* Force light theme on initial load and after every View Transitions swap. */}
<script is:inline>
  try { localStorage.setItem('starlight-theme', 'light'); } catch (_) {}
  document.documentElement.setAttribute('data-theme', 'light');
  // astro:after-swap fires after each client-side navigation DOM swap.
  // This script is deduplicated by Astro (same content = not re-run), but the
  // listener added here persists in memory and corrects data-theme after every swap.
  document.addEventListener('astro:after-swap', function () {
    document.documentElement.setAttribute('data-theme', 'light');
  });
</script>
<title>{title}</title>
{widgetScriptSrc && <link rel="preload" href={widgetScriptSrc} as="script" />}
{description && <meta name="description" content={description} />}
{keywords && <meta name="keywords" content={keywords} />}
{passthroughHead.map((entry) => {
    const { tag: Tag, attrs, content } = entry;
    return content ? <Tag {...attrs} set:html={content} /> : <Tag {...attrs} />;
})}
<ClientRouter />


