---
/**
 * Composes the sidebar:
 *   <sidebar-filter>
 *     <SidebarFilterInput />            ← always visible (above the scroll)
 *     <div data-sidebar-scroll>         ← only this scrolls
 *       <SidebarTree />                 ← recursive, no string templating
 *     </div>
 *   </sidebar-filter>
 *
 * Filter visibility is CSS-driven by `[data-filtering]` on the host and
 * `[data-filter-match]` on each <li>. No JS toggles `hidden` / classes.
 *
 * Initial expand/collapse comes from each group's `collapsed` flag (set by
 * `buildSidebarFromToc` — root groups: `collapsed:false`, nested: `collapsed:true`)
 * combined with active-path auto-open. See `lib/sidebar/helpers.ts#isInitiallyOpen`.
 */
import { sidebar as sidebarData } from 'virtual:docs-template/site-meta';
import SidebarFilterInput from './SidebarFilterInput.astro';
import SidebarTree from './SidebarTree.astro';
import type { SidebarEntry } from '../../lib/sidebar/types';

interface Props {
  currentSlug?: string;
}

const { currentSlug = '' } = Astro.props;
const items = sidebarData as SidebarEntry[];
---

<sidebar-filter id="docs-sidebar" data-no-results="No topics match">
  <SidebarFilterInput />
  <div class="sidebar-scroll" data-sidebar-scroll>
    <SidebarTree items={items} currentSlug={currentSlug} />
  </div>
</sidebar-filter>

<script>
  import './sidebar-filter';
</script>

<style>
  /* ── Layout: filter pinned, only the items scroll ───────────────────── */
  sidebar-filter {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
  }

  .sidebar-scroll {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    /* Pull to the full pane width so the scrollbar sits flush with the edge */
    margin-inline-end: calc(-1 * var(--sl-sidebar-pad-x, 1rem));
    padding-inline-end: var(--sl-sidebar-pad-x, 1rem);
  }

  /* ── Lists ──────────────────────────────────────────────────────────── */
  :global(.sidebar-list),
  :global(.sidebar-group-items) {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  :global(.sidebar-group) {
    margin-block: 0.25rem;
  }

  :global(.sidebar-group-items) {
    padding-inline-start: 0.75rem;
    border-inline-start: 1px solid var(--sl-color-hairline, #e2e4e9);
    margin-inline-start: 0.25rem;
  }

  /* ── Group summary + caret on the right ─────────────────────────────── */
  :global(details summary) {
    cursor: pointer;
    list-style: none;
    padding: 0.25rem 0;
  }
  :global(details summary::-webkit-details-marker) { display: none; }

  :global(.group-label) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--sl-text-xs, 0.75rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--sl-color-gray-3, #888);
    padding: 0.5rem 0 0.25rem;
  }

  :global(.group-label-text) {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Caret pinned to the trailing edge of the row */
  :global(.group-caret) {
    flex-shrink: 0;
    margin-inline-start: auto;
    color: var(--sl-color-gray-3, #888);
    transform: rotate(0deg);
    transition: transform 120ms ease-out;
  }
  :global(details[open] > summary > .group-caret) {
    transform: rotate(90deg);
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.group-caret) { transition: none; }
  }

  /* ── Links ──────────────────────────────────────────────────────────── */
  :global(.sidebar-list a),
  :global(.sidebar-group-items a) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.5rem;
    border-radius: 0.25rem;
    font-size: var(--sl-text-sm, 0.875rem);
    color: var(--sl-color-text, inherit);
    text-decoration: none;
    line-height: 1.4;
  }

  :global(.sidebar-list a:hover),
  :global(.sidebar-group-items a:hover) {
    background: color-mix(in srgb, var(--sl-color-accent) 8%, transparent);
    color: var(--sl-color-accent, #3b82f6);
    text-decoration: none;
  }

  :global(.sidebar-list a[aria-current='page']),
  :global(.sidebar-group-items a[aria-current='page']) {
    background: color-mix(in srgb, var(--sl-color-accent) 12%, transparent);
    color: var(--sl-color-accent, #3b82f6);
    font-weight: 600;
  }

  :global(.link-label) {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ── Badges ─────────────────────────────────────────────────────────── */
  :global(.sl-badge) {
    display: inline-flex;
    align-items: center;
    border-radius: 0.25rem;
    padding: 0.1rem 0.35rem;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid currentColor;
    margin-inline-start: auto;
    flex-shrink: 0;
  }
  :global(.sl-badge.default) { color: var(--sl-color-gray-3); }
  :global(.sl-badge.note)    { color: hsl(234, 90%, 60%); }
  :global(.sl-badge.tip)     { color: hsl(134, 70%, 38%); }
  :global(.sl-badge.success) { color: hsl(134, 70%, 38%); }
  :global(.sl-badge.caution) { color: hsl(40, 90%, 45%); }
  :global(.sl-badge.danger)  { color: hsl(0, 85%, 52%); }

  /* ── Filter visibility (purely attribute-driven) ───────────────────── */
  sidebar-filter[data-filtering] :global(li[data-path]:not([data-filter-match])) {
    display: none;
  }
</style>
