---
/**
 * Filter input UI for the docs sidebar.
 * Markup-only — behavior lives in `./sidebar-filter.ts`.
 */
---

<div class="sidebar-filter-wrapper" role="search" aria-label="Filter sidebar topics">
  <div class="sidebar-filter-field">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="sidebar-filter-icon"
      viewBox="0 0 16 16"
      aria-hidden="true"
      focusable="false"
      width="14"
      height="14"
      fill="none"
    >
      <path d="M1 3h14M4 8h8M7 13h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
    <input
      id="sidebar-filter-input"
      type="search"
      autocomplete="off"
      spellcheck="false"
      placeholder="Filter topics…"
      aria-label="Filter navigation topics"
      aria-controls="docs-sidebar"
      data-sidebar-filter-input
    />
    <button type="button" aria-label="Clear filter" hidden data-sidebar-filter-clear>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14" aria-hidden="true" focusable="false" width="12" height="12">
        <path d="M2 2l10 10M12 2 2 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>
  <p
    role="status"
    aria-atomic="true"
    class="sidebar-filter-status"
    data-sidebar-filter-status
  ></p>
</div>

<style>
  /* Sits above the scroll container — always visible, never scrolls. */
  .sidebar-filter-wrapper {
    flex-shrink: 0;
    margin-block-end: 0.5rem;
    padding-block-end: 0.25rem;
    background: var(--sl-color-bg-sidebar, var(--sl-color-bg));
  }

  .sidebar-filter-field {
    position: relative;
    display: flex;
    align-items: center;
  }

  .sidebar-filter-icon {
    position: absolute;
    inset-inline-start: 0.5rem;
    color: var(--sl-color-gray-3);
    pointer-events: none;
    flex-shrink: 0;
  }

  .sidebar-filter-field input {
    width: 100%;
    padding: 0.35rem 2rem 0.35rem 1.75rem;
    background: var(--sl-color-bg-inline-code, var(--sl-color-bg));
    border: 1px solid var(--sl-color-hairline-light, #e2e4e9);
    border-radius: 0.25rem;
    color: var(--sl-color-text);
    font-size: var(--sl-text-xs, 0.75rem);
    font-family: inherit;
    line-height: 1.4;
    -webkit-appearance: none;
    appearance: none;
  }

  .sidebar-filter-field input::-webkit-search-cancel-button,
  .sidebar-filter-field input::-webkit-search-decoration {
    -webkit-appearance: none;
  }

  .sidebar-filter-field input::placeholder {
    color: var(--sl-color-gray-4);
  }

  .sidebar-filter-field input:focus {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 0;
    border-color: var(--sl-color-accent);
  }

  .sidebar-filter-field button[data-sidebar-filter-clear] {
    position: absolute;
    inset-inline-end: 0.4rem;
    padding: 0.2rem;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--sl-color-gray-3);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.2rem;
  }

  .sidebar-filter-field button[data-sidebar-filter-clear][hidden] {
    display: none;
  }

  .sidebar-filter-field button[data-sidebar-filter-clear]:hover {
    color: var(--sl-color-text);
  }

  .sidebar-filter-field button[data-sidebar-filter-clear]:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 0;
  }

  .sidebar-filter-status {
    margin: 0.25rem 0 0;
    font-size: 0.7rem;
    color: var(--sl-color-gray-3);
    min-height: 1em;
    padding-inline-start: 0.1rem;
  }
</style>
