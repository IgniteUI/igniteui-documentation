---
import noteIcon    from '../../icons/aside/note.svg?raw';
import tipIcon     from '../../icons/aside/tip.svg?raw';
import cautionIcon from '../../icons/aside/caution.svg?raw';
import dangerIcon  from '../../icons/aside/danger.svg?raw';

interface Props {
  type?: 'note' | 'tip' | 'caution' | 'danger';
  title?: string;
  color?: string;
  class?: string;
  icon?: string;
}

const { type = 'note', title, color, icon, class: className } = Astro.props;

const defaultLabels: Record<string, string> = {
  note: 'Note',
  tip: 'Tip',
  caution: 'Caution',
  danger: 'Danger',
};

const defaultIcons: Record<string, string> = {
  note: noteIcon,
  tip: tipIcon,
  caution: cautionIcon,
  danger: dangerIcon,
};

const label = title ?? defaultLabels[type];
const resolvedIcon = icon !== undefined ? icon : defaultIcons[type];
const inlineStyle = color ? `--aside-color: ${color};` : undefined;
---

<aside
  class:list={['aside', `aside--${type}`, className]}
  aria-label={label}
  style={inlineStyle}
>
  <p class="aside-title" aria-hidden="true">
    {resolvedIcon && <span class="aside-icon" aria-hidden="true" set:html={resolvedIcon} />}
    {label}
  </p>
  <section class="aside-content">
    <slot />
  </section>
</aside>

<style>
  .aside {
    --aside-color: hsl(234, 90%, 60%);
    border-inline-start: 0.25rem solid var(--aside-color);
    padding: 1rem 1.25rem;
    background-color: color-mix(in srgb, var(--aside-color) 8%, transparent);
    border-radius: 0 0.375rem 0.375rem 0;
    margin: 1.5rem 0;
  }
  .aside--note    { --aside-color: hsl(234, 90%, 60%); }
  .aside--tip     { --aside-color: hsl(134, 70%, 38%); }
  .aside--caution { --aside-color: hsl(40,  90%, 45%); }
  .aside--danger  { --aside-color: hsl(0,   85%, 52%); }

  .aside-title {
    display: flex;
    align-items: center;
    gap: 0.4em;
    font-weight: 700;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--aside-color);
    margin: 0 0 0.5rem;
  }
  .aside-icon {
    display: inline-flex;
    flex-shrink: 0;
  }
  .aside-icon :global(svg) {
    width: 1.4em;
    height: 1.4em;
    fill: currentColor;
  }
  .aside-content > :first-child { margin-top: 0; }
  .aside-content > :last-child  { margin-bottom: 0; }
</style>
