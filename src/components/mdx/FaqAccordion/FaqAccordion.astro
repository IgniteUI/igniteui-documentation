---
import './FaqAccordion.scss';

/**
 * FaqAccordion.astro
 *
 * Wraps <igc-accordion> for use in MDX content pages.
 * The <script> block registers IgcAccordionComponent and IgcExpansionPanelComponent
 * exactly once per page (Astro deduplicates module scripts).
 *
 * Usage in MDX:
 *   import FaqAccordion from 'docs-template/components/mdx/FaqAccordion.astro';
 *
 *   <FaqAccordion>
 *     <igc-expansion-panel>
 *       <span slot="title">Question?</span>
 *       Answer text.
 *     </igc-expansion-panel>
 *   </FaqAccordion>
 */
---

<igc-accordion class="faq-accordion">
    <slot />
</igc-accordion>

<script>
    // Astro deduplicates module scripts — this runs exactly once per full page load.
    import { defineComponents, IgcAccordionComponent, IgcExpansionPanelComponent } from 'igniteui-webcomponents';
    defineComponents(IgcAccordionComponent, IgcExpansionPanelComponent);
</script>
