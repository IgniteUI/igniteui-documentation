---
/**
 * GlobalFooter
 *
 * Renders the product-specific bottom footer, equivalent to what the old
 * igniteui-docfx-template rendered via:
 *   - template/partials/footer.tmpl.partial  (dispatcher)
 *   - template/partials/infrafoot.tmpl.partial         (IG EN)
 *   - template/partials/infrafoot.ja.tmpl.partial      (IG JA)
 *   - template/partials/infrafoot.kr.tmpl.partial      (IG KR)
 *   - template/partials/revealfoot.tmpl.partial        (Reveal EN)
 *   - template/partials/revealfoot.ja.tmpl.partial     (Reveal JA)
 *   - template/partials/appbuilder/appbuilderfoot.tmpl.partial
 *   - template/partials/slingshot/slingshotfoot.tmpl.partial
 *
 * This component is separate from Starlight's own Footer override (which
 * provides the "Edit this page" link and pagination). Mount it INSIDE the
 * Starlight Footer override to place it below the docs navigation footer.
 *
 * Props:
 *   theme – product theme (default: 'igniteui')
 *   lang  – locale       (default: 'en')
 */
interface Props {
  theme?: 'igniteui' | 'appbuilder' | 'reveal' | 'slingshot';
  lang?: 'en' | 'ja' | 'kr';
}

import { prefetched, uiFooterHtml, footerHtml } from 'virtual:docs-template/nav-html';

const { theme = 'igniteui', lang = 'en' } = Astro.props;

const isJa = lang === 'ja';
const isKr = lang === 'kr';
const igBase       = isJa ? 'https://jp.infragistics.com' : 'https://www.infragistics.com';
const isIgniteUI   = theme === 'igniteui';
const isReveal     = theme === 'reveal';
const isAppBuilder = theme === 'appbuilder';
const isSlingshot  = theme === 'slingshot';
const year = new Date().getFullYear();
---

{/* === IgniteUI / default Infragistics footer === */}
