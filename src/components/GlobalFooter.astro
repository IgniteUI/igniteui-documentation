{/* === AppBuilder footer (dynamically loaded from CMS) === */}
{isAppBuilder && (
  <>
    <div id="ab-footer-container"></div>
    <script is:inline>
      (function () {
        var domain = window.location.origin.includes('staging') || window.location.origin.includes('localhost')
          ? 'https://staging.appbuilder.dev'
          : 'https://www.appbuilder.dev';
        var xhr = new XMLHttpRequest();
        xhr.open('GET', domain + '/header-footer-export', true);
        xhr.onload = function () {
          if (xhr.status >= 200 && xhr.status < 400) {
            try {
              var data = JSON.parse(xhr.responseText);
              if (data.footer) {
                document.getElementById('ab-footer-container').innerHTML = data.footer;
              }
            } catch (e) { /* ignore */ }
          }
        };
        xhr.send();
      })();
    </script>
  </>
)}

