      <template id="ig-footer-tpl">
        <Fragment set:html={uiFooterHtml} />
      </template>
      <script is:inline>
      (function () {
      var STYLE_URLS = [
        'https://www.infragistics.com/DependencyHandler.axd?&t=Css&cdv=20260306',
      ];
      var SCRIPT_QUEUE = [
        {
          src: 'https://www.infragistics.com/DependencyHandler.axd?&t=Javascript&cdv=20260306',
        },
      ];

        function loadScript(item) {
          return new Promise(function (resolve) {
            if (item.src.indexOf('jquery') !== -1 && window.jQuery) { resolve(); return; }
            var s = document.createElement('script');
            s.src = item.src;
            if (item.integrity) { s.integrity = item.integrity; s.crossOrigin = item.crossOrigin || 'anonymous'; }
            s.onload  = resolve;
            s.onerror = resolve;
            document.head.appendChild(s);
          });
        }

        function mountFooterShadow() {
          var host = document.getElementById('ig-footer');
          var tpl  = document.getElementById('ig-footer-tpl');
          if (!host || !tpl || host.shadowRoot) return;

          var shadow = host.attachShadow({ mode: 'open' });

          STYLE_URLS.forEach(function (href) {
            var link = document.createElement('link');
            link.rel  = 'stylesheet';
            link.href = href;
            shadow.appendChild(link);
          });

          shadow.appendChild(tpl.content.cloneNode(true));

          SCRIPT_QUEUE.reduce(function (chain, item) {
            return chain.then(function () { return loadScript(item); });
          }, Promise.resolve());
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', mountFooterShadow);
        } else {
          mountFooterShadow();
        }
      })();
      </script>
    </>
  ) : (
