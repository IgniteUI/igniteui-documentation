---
// src/components/SidebarFilterInput.astro
// Filter input UI for the sidebar navigation.
// Must be rendered inside a <sidebar-filter> custom element.
---

<div class="sidebar-filter-wrapper">
  <label for="sidebar-filter-input" class="sl-sr-only">Filter navigation</label>
  <div class="sidebar-filter-field">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="sidebar-filter-icon"
      viewBox="0 0 16 16"
      aria-hidden="true"
      focusable="false"
      width="14"
      height="14"
      fill="none"
    >
      <circle cx="6.5" cy="6.5" r="5" stroke="currentColor" stroke-width="1.5"/>
      <path d="M10.5 10.5L14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
    <input
      id="sidebar-filter-input"
      type="search"
      autocomplete="off"
      spellcheck="false"
      placeholder="Filter topics…"
      aria-label="Filter navigation topics"
      role="searchbox"
      data-sidebar-filter-input
    />
    <button type="button" aria-label="Clear filter" hidden data-sidebar-filter-clear>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14" aria-hidden="true" focusable="false" width="12" height="12">
        <path d="M2 2l10 10M12 2 2 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>
  <p
    role="status"
    aria-live="polite"
    aria-atomic="true"
    class="sidebar-filter-status"
    data-sidebar-filter-status
  ></p>
</div>

<style>
  @layer starlight.user {
    .sidebar-filter-wrapper {
      padding: 0.5rem var(--sl-sidebar-pad-x, 1rem);
      padding-bottom: 0.25rem;
      border-bottom: 1px solid var(--sl-color-hairline-light);
      margin-bottom: 0.5rem;
    }

    .sidebar-filter-field {
      position: relative;
      display: flex;
      align-items: center;
    }

    .sidebar-filter-icon {
      position: absolute;
      inset-inline-start: 0.5rem;
      color: var(--sl-color-gray-3);
      pointer-events: none;
      flex-shrink: 0;
    }

    .sidebar-filter-field input {
      width: 100%;
      padding: 0.35rem 2rem 0.35rem 1.75rem;
      background: var(--sl-color-bg-inline-code);
      border: 1px solid var(--sl-color-hairline-light);
      border-radius: 0.25rem;
      color: var(--sl-color-text);
      font-size: var(--sl-text-xs);
      font-family: inherit;
      line-height: 1.4;
      -webkit-appearance: none;
      appearance: none;
    }

    .sidebar-filter-field input::-webkit-search-cancel-button,
    .sidebar-filter-field input::-webkit-search-decoration {
      -webkit-appearance: none;
    }

    .sidebar-filter-field input::placeholder {
      color: var(--sl-color-gray-4);
    }

    .sidebar-filter-field input:focus {
      outline: 2px solid var(--sl-color-accent);
      outline-offset: 0;
      border-color: var(--sl-color-accent);
    }

    .sidebar-filter-field button[data-sidebar-filter-clear] {
      position: absolute;
      inset-inline-end: 0.4rem;
      padding: 0.2rem;
      background: transparent;
      border: none;
      cursor: pointer;
      color: var(--sl-color-gray-3);
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 0.2rem;
    }

    .sidebar-filter-field button[data-sidebar-filter-clear]:hover {
      color: var(--sl-color-white);
    }

    .sidebar-filter-field button[data-sidebar-filter-clear]:focus-visible {
      outline: 2px solid var(--sl-color-accent);
      outline-offset: 0;
    }

    .sidebar-filter-status {
      margin: 0.25rem 0 0;
      font-size: var(--sl-text-2xs);
      color: var(--sl-color-gray-3);
      min-height: 1em;
      padding-inline-start: 0.1rem;
    }
  }
</style>
