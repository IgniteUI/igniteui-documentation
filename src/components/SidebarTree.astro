---
/**
 * Recursive sidebar tree renderer. Emits a <ul> of <SidebarItem>s.
 */
import SidebarItem from './SidebarItem.astro';
import type { SidebarEntry } from './sidebar-types';

interface Props {
  items: SidebarEntry[];
  ancestors?: string[];
  currentSlug: string;
}

const { items, ancestors = [], currentSlug } = Astro.props;
const isRoot = ancestors.length === 0;
---

<ul class={isRoot ? 'sidebar-list' : 'sidebar-group-items'}>
  {items.map((item) => (
    <SidebarItem item={item} ancestors={ancestors} currentSlug={currentSlug} />
  ))}
</ul>
