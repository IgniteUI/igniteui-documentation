---
/**
 * GlobalNavBar
 *
 * Renders the platform-appropriate global navigation bar directly in the
 * light DOM. Platform is driven by `siteMetaIntegration({ platform })` in
 * astro.config.ts (exported from the virtual module) and can be overridden
 * per-instance via the `theme` prop.
 *
 * Platforms:
 *   igniteui / angular / react / blazor / web-components / slingshot
 *     → IG global nav (infragistics.com). Prebuild path uses virtual module
 *       headerHtml. Static fallback renders the minimal nav server-side.
 *   appbuilder
 *     → AppBuilder nav (appbuilder.dev). Prebuild uses abHeaderHtml.
 *       Runtime fallback uses the XHR includeContent pattern.
 *
 * CDN styles/scripts for each platform are already injected into <head> by
 * getPlatformHead() in astro.config.ts — not repeated here.
 */
import {
  platform as virtualPlatform,
  navLang as virtualNavLang,
  prefetched,
  headerHtml,
  abPrefetched,
  abHeaderHtml,
} from 'virtual:docs-template/nav-html';
import styles from './GlobalNavBar.module.scss';
import type { NavLang, NavTheme } from '../platform.ts';

interface Props {
  /** Override the platform for this instance. Defaults to virtual module value. */
  theme?: NavTheme;
  /** Override the locale. Defaults to virtual module navLang. */
  lang?: NavLang;
}

const { theme, lang } = Astro.props as Props;

// Props override the virtual module values (allows per-page overrides)
const resolvedPlatform = theme ?? virtualPlatform ?? 'igniteui';
const resolvedLang = (lang ?? virtualNavLang ?? 'en') as 'en' | 'jp' | 'kr';

const isJa = resolvedLang === 'jp';
const isKr = resolvedLang === 'kr';
const isAppBuilder = resolvedPlatform === 'appbuilder';
// All IG-family platforms share the same global nav
const isIgPlatform = !isAppBuilder;

const igBase = isJa ? 'https://jp.infragistics.com' : 'https://www.infragistics.com';
---

{/* ============================================================
    IG-family global nav (angular, react, blazor, web-components,
    slingshot, igniteui)
    ============================================================ */}
<div class={styles.navBar}>
  {/* Prebuild path — HTML captured at build time */}
  {isIgPlatform && prefetched && (
    <>
      <Fragment set:html={headerHtml} />
      <script is:inline data-astro-rerun>
        function initNav() {
          if (window.igNavigation && typeof window.igNavigation.init === 'function') {
            window.igNavigation.init();
          }
        }
      
        document.addEventListener('astro:page-load', initNav);
      </script>
    </>
  )}

  {/* Static fallback — rendered when prefetch is unavailable */}
  {isIgPlatform && !prefetched && (
  <header id="header" class="globalnav" data-nav-auto-init="false">
    <section id="header-wrap" class="globalnav__container" data-default-height="175" data-sticky-height="60">
      <section class="globalnav__primary clearfix">
        <div class="globalnav__wrapper">
          <div class="globalnav__brand">
            <a href={igBase}>
              <img class="globalnav__logo" src="https://static.infragistics.com/marketing/Website/products/ignite-ui/ignite-ui-logo.svg" alt="Infragistics Logo" />
            </a>
          </div>
          <nav class="globalnav__nav">
            {isJa ? (
              <ul class="globalnav__menu">
                <li class="globalnav__item"><a class="globalnav__link" href="https://jp.infragistics.com/products">製品</a></li>
                <li class="globalnav__item"><a class="globalnav__link" href="https://jp.infragistics.com/community/blogs">ブログ</a></li>
                <li class="globalnav__item"><a class="globalnav__link" href="https://jp.infragistics.com/support">サポート</a></li>
              </ul>
            ) : isKr ? (
              <ul class="globalnav__menu">
                <li class="globalnav__item"><a class="globalnav__link" href="https://www.infragistics.com/products">제품</a></li>
                <li class="globalnav__item"><a class="globalnav__link" href="https://www.infragistics.com/community/blogs">블로그</a></li>
                <li class="globalnav__item"><a class="globalnav__link" href="https://www.infragistics.com/support">지원</a></li>
              </ul>
            ) : (
              <ul class="globalnav__menu">
                <li class="globalnav__item"><a class="globalnav__link" href="https://www.infragistics.com/products">Products</a></li>
                <li class="globalnav__item"><a class="globalnav__link" href="https://www.infragistics.com/community/blogs">Blog</a></li>
                <li class="globalnav__item"><a class="globalnav__link" href="https://www.infragistics.com/support">Support</a></li>
              </ul>
            )}
          </nav>
          <div class="globalnav__overlay"></div>
        </div>
      </section>
    </section>
  </header>
  )}

  {/* ============================================================
      AppBuilder nav
      ============================================================ */}
  {isAppBuilder && (
    <>
      {/* Prebuild path — AB header HTML captured at build time */}
      {abPrefetched && (
        <>
          <Fragment set:html={abHeaderHtml} />
          <script is:inline>
          window.addEventListener('load', function () {
            // Fix language-bar links (depends on current page URL at runtime)
            var langBar = document.querySelector('.mega-lang-bar');
            if (langBar) {
              langBar.innerHTML =
                '<a class="mega-custom-icon mega-menu-link" href="#" aria-expanded="false" tabindex="0" aria-label="LangBar">' +
                '<span class="mega-indicator" aria-hidden="true"></span></a>' +
                '<ul class="mega-sub-menu"><li class="mega-menu-item" id="mega-menu-item-8148"><div class="wovn-languages">' +
                '<a href="' + window.location.href.replace('/jp/help/', '/help/') + '" style="display:block;padding-left:10px;color:gray;font-weight:300;">English</a>' +
                '<a href="' + window.location.href.replace('/help/', '/jp/help/') + '" style="display:block;padding-left:10px;color:gray;font-weight:300;">日本語</a>' +
                '</div></li></ul>';
            }
            // Initialise mega menu
            if (window.jQuery && typeof window.jQuery('.max-mega-menu').maxmegamenu === 'function') {
              window.jQuery('.max-mega-menu').maxmegamenu();
            }
            // Search toggle
            var searchIcon  = document.querySelector('.mega-search .search-icon');
            var searchInput = document.querySelector('.mega-search input[type=text]');
            if (searchIcon)  searchIcon.onclick  = function () { _abSearchToggle(); };
            if (searchInput) searchInput.onblur  = function () { _abSearchToggle(); };

            function _abSearchToggle() {
              var form = document.querySelector('.mega-search');
              var inp  = document.querySelector('.mega-search input[type=text]');
              if (!form) return;
              if (form.classList.contains('mega-search-open')) {
                form.classList.replace('mega-search-open', 'mega-search-closed');
                if (inp) { inp.setAttribute('placeholder', ''); inp.value = ''; inp.setAttribute('tabindex', '0'); }
              } else {
                form.classList.replace('mega-search-closed', 'mega-search-open');
                if (inp) { inp.setAttribute('placeholder', 'Search...'); inp.focus(); inp.setAttribute('tabindex', '-1'); }
              }
            }
          });
          </script>
        </>
      )}

      {/*
        Runtime fallback — XHR fetch of AB header at page load.
        ---------------------------------------------------------
        This path executes when the build-time prefetch of
        https://www.appbuilder.dev/header-footer-export was unavailable
        (abPrefetched === false).

        It fires a client-side XHR on window load and injects the returned
        headerHtml into #ab-nav-container. The footerHtml is appended to
        document.getElementById('footer'), which may conflict with the
        GlobalFooter component rendered by CustomPageFrame.

        Known downsides:
          - Visible layout shift: header appears only after the page load event.
          - Requires the client to reach appbuilder.dev at runtime (cross-origin).
          - The footer injection target (#footer) is fragile and couples
            this component to the DOM shape of GlobalFooter.

        TODO: Consider removing this fallback entirely. If the build-time
        prefetch is consistently reliable, this branch is never reached. A static
        minimal fallback or a clear error state would be more predictable than a
        delayed XHR-driven render.
      */}
      {!abPrefetched && (
      <>
        <div id="ab-nav-container"></div>
        <script is:inline>
          (function () {
            var includeContent = {
              settings: {
                url: 'https://www.appbuilder.dev/header-footer-export',
                selector: '#header-container',
              },
              processInclude: function () {
                var self = this;
                var xhr = new XMLHttpRequest();
                xhr.open('GET', self.settings.url, true);
                xhr.onreadystatechange = function () {
                  if (xhr.readyState === 4 && xhr.status === 200) {
                    try {
                      var data    = JSON.parse(xhr.responseText);
                      var header  = data.headerHtml  || '';
                      var footer  = data.footerHtml  || '';
                      var container = document.getElementById('ab-nav-container');
                      if (container) container.innerHTML = header;
                      var footerEl = document.getElementById('footer');
                      if (footerEl) footerEl.innerHTML += footer;
                    } catch (e) {
                      /* no-op – nav unavailable */
                    }
                  }
                };
                xhr.send();
              },
            };
            window.addEventListener('load', function () {
              includeContent.processInclude();
            });
          })();
        </script>
      </>
      )}
    </>
  )}

</div>
