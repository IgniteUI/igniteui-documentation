---
/**
 * GlobalNavBar
 *
 * Renders the Infragistics global navigation bar, equivalent to what the old
 * igniteui-docfx-template rendered via:
 *   - template/partials/navbar.tmpl.partial  (dispatcher)
 *   - template/partials/infranav.tmpl.partial         (EN)
 *   - template/partials/infranav.ja.tmpl.partial      (JA)
 *   - template/partials/infranav.kr.tmpl.partial      (KR)
 *   - template/partials/revealnav.tmpl.partial        (Reveal EN)
 *   - template/partials/revealnav.ja.tmpl.partial     (Reveal JA)
 *   - template/partials/appbuilder/navbar.tmpl.partial (AppBuilder)
 *   - template/partials/slingshot/navbar.tmpl.partial  (Slingshot)
 *
 * CDN assets from infragistics.com are required for the IgniteUI/default
 * theme. They are loaded as link/script tags inside this component and the
 * browser handles them correctly even when placed outside <head>.
 *
 * Props:
 *   theme – which product nav to show (default: 'igniteui')
 *   lang  – locale (default: 'en')
 */

import { prefetched, headerHtml } from 'virtual:docs-template/nav-html';

interface Props {
  theme?: 'igniteui' | 'appbuilder' | 'reveal' | 'slingshot';
  lang?: 'en' | 'ja' | 'kr';
}

const { theme = 'igniteui', lang = 'en' } = Astro.props;

const isJa = lang === 'ja';
const isKr = lang === 'kr';

// CDN base for locale-aware links
const igBase = isJa ? 'https://jp.infragistics.com' : 'https://www.infragistics.com';

// Reveal product links
const revealHref = isJa ? 'https://www.revealbi.io/jp/' : 'https://www.revealbi.io';

// Per-theme flags
const isIgniteUI   = theme === 'igniteui';
const isReveal     = theme === 'reveal';
const isAppBuilder = theme === 'appbuilder';
const isSlingshot  = theme === 'slingshot';
// Slingshot docs share the IG global nav header
const useIgGlobalNav = isIgniteUI || isSlingshot;
---

{/* === IgniteUI / Slingshot global nav (fetched at build time, mounted in Shadow DOM) === */}
{useIgGlobalNav && prefetched && (
  <>
    {/*
      The <header> element is an empty shadow host at render time.
      CDN stylesheets + nav HTML are injected into its shadow root by the
      inline script below — so they are fully isolated from Starlight's styles.
    */}
    <header id="header" class="globalnav" data-nav-auto-init="false"></header>

    {/* Server-rendered nav HTML stored in a hidden template for the client script */}
    <template id="ig-nav-tpl">
      <Fragment set:html={headerHtml} />
    </template>

    <script is:inline>
    (function () {
      var STYLE_URLS = [
        'https://www.infragistics.com/DependencyHandler.axd?&t=Css&cdv=20260306',
              'https://www.infragistics.com/assets/modern/css/layout.css',
        'https://www.infragistics.com/assets/modern/css/animate-custom.css',
        'https://www.infragistics.com/assets/modern/css/fontello.css',
        'https://www.infragistics.com/css/navigation.css',
      ];
      var SCRIPT_QUEUE = [
        {
          src: 'https://www.infragistics.com/DependencyHandler.axd?&t=Javascript&cdv=20260306',
        },
        {
          src: 'https://code.jquery.com/jquery-3.1.0.js',
          integrity: 'sha256-slogkvB1K3VOkzAI8QITxV3VzpOnkeNVsKvtkYLMjfk=',
          crossOrigin: 'anonymous',
        },
                { src: 'https://www.infragistics.com/assets/modern/scripts/plugins.nav.js' },
        { src: 'https://www.infragistics.com/assets/modern/scripts/navigation.js' },
      ];

      function loadScript(item) {
        return new Promise(function (resolve) {
          var s = document.createElement('script');
          s.src = item.src;
          if (item.integrity) { s.integrity = item.integrity; s.crossOrigin = item.crossOrigin || 'anonymous'; }
          s.onload  = resolve;
          s.onerror = resolve;
          document.head.appendChild(s);
        });
      }

      function mountNavShadow() {
        var host = document.getElementById('header');
        var tpl  = document.getElementById('ig-nav-tpl');
        if (!host || !tpl || host.shadowRoot) return;

        var shadow = host.attachShadow({ mode: 'open' });

        // Inject CDN stylesheets inside the shadow root for full isolation
        STYLE_URLS.forEach(function (href) {
          var link = document.createElement('link');
          link.rel  = 'stylesheet';
          link.href = href;
          shadow.appendChild(link);
        });

        // Clone server-rendered nav HTML into the shadow root
        shadow.appendChild(tpl.content.cloneNode(true));

        // Load nav scripts sequentially, then initialise
        SCRIPT_QUEUE.reduce(function (chain, item) {
          return chain.then(function () { return loadScript(item); });
        }, Promise.resolve()).then(function () {
          if (window.igNavigation && typeof window.igNavigation.init === 'function') {
            window.igNavigation.init();
          }
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', mountNavShadow);
      } else {
        mountNavShadow();
      }
    })();
    </script>
  </>
)}
