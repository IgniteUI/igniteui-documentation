---
/**
 * SidebarAccordionTrigger
 *
 * Mobile-only accordion button that expands/collapses the sidebar inline.
 * Must be rendered as a direct sibling of .sidebar-pane inside the <nav>
 * element so the CSS sibling selector drives visibility without JS:
 *
 *   .sidebar-accordion-trigger[aria-expanded='true'] ~ .sidebar-pane { … }
 *
 * Props:
 *   label  – visible button text (e.g. group name). Default: 'Components List'.
 */
interface Props {
  label?: string;
}
const { label = 'Components List' } = Astro.props;
---

<button
  id="sidebar-accordion-trigger"
  class="sidebar-accordion-trigger"
  aria-expanded="false"
  aria-controls="starlight__sidebar"
  aria-label={`Toggle ${label} sidebar`}
>
  <span class="trigger-label">{label}</span>
  <svg
    class="chevron"
    xmlns="http://www.w3.org/2000/svg"
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <polyline points="6 9 12 15 18 9" />
  </svg>
</button>

<script>
  const trigger = document.getElementById('sidebar-accordion-trigger');
  if (trigger) {
    trigger.addEventListener('click', () => {
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      trigger.setAttribute('aria-expanded', String(!expanded));
      document.body.toggleAttribute('data-mobile-menu-expanded', !expanded);
    });
    document.addEventListener('keyup', (e) => {
      if (e.key === 'Escape' && trigger.getAttribute('aria-expanded') === 'true') {
        trigger.setAttribute('aria-expanded', 'false');
        document.body.removeAttribute('data-mobile-menu-expanded');
        trigger.focus();
      }
    });
  }
</script>

<style>
  @layer starlight.core {
    .sidebar-accordion-trigger {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      padding: 0.6rem var(--sl-sidebar-pad-x, 1rem);
      background: var(--sl-color-bg-sidebar);
      border: none;
      border-bottom: 1px solid var(--sl-color-hairline-shade);
      cursor: pointer;
      color: var(--sl-color-text-accent);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .chevron {
      flex-shrink: 0;
      transition: transform 0.2s ease;
    }

    .sidebar-accordion-trigger[aria-expanded='true'] .chevron {
      transform: rotate(180deg);
    }

    @media (min-width: 50rem) {
      .sidebar-accordion-trigger {
        display: none;
      }
    }
  }
</style>
