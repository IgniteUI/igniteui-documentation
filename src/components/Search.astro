---
/**
 * Search
 *
 * Pagefind-powered full-text search modal.
 * The search index (/pagefind/) is generated by `pagefind --site <outDir>`
 * at the end of every production build (wired in siteMetaIntegration).
 *
 * In development the button is rendered but the dynamic import will 404
 * gracefully — no errors surface to the user.
 */
---

<button
  id="search-trigger"
  class="search-trigger"
  aria-label="Search documentation"
  title="Search (Ctrl+K)"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
       fill="none" stroke="currentColor" stroke-width="2"
       stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="11" cy="11" r="8"/>
    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
  </svg>
  <span class="search-trigger-hint">Ctrl+K</span>
</button>

<dialog id="search-dialog" class="search-dialog" aria-label="Search">
  <div class="search-dialog-inner">
    <div id="search-pagefind"></div>
  </div>
</dialog>

<script>
  // BASE_URL accounts for non-root deployments, e.g. /products/ignite-ui-angular/...
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');

  // With ClientRouter, this script re-runs on every navigation.
  // State is kept on `window` so it survives re-executions.
  const _w = window as any;

  async function openSearch() {
    const dialog = document.getElementById('search-dialog') as HTMLDialogElement | null;
    if (!dialog) return;

    // Load pagefind-ui.js only once — it's an IIFE that sets window.PagefindUI.
    // Checking window.PagefindUI avoids appending a duplicate <script> tag whose
    // onload never fires (cached scripts don't re-trigger onload).
    if (!_w.PagefindUI) {
      try {
        const link = Object.assign(document.createElement('link'), {
          rel: 'stylesheet',
          href: `${base}/pagefind/pagefind-ui.css`,
        });
        document.head.appendChild(link);

        await new Promise<void>((resolve, reject) => {
          const s = document.createElement('script');
          s.src = `${base}/pagefind/pagefind-ui.js`;
          s.onload = () => resolve();
          s.onerror = () => reject(new Error('Failed to load pagefind-ui.js'));
          document.head.appendChild(s);
        });
      } catch (err) {
        console.error('[Search] pagefind failed to load:', err);
        const el = document.getElementById('search-pagefind');
        if (el) el.textContent = 'Search index not available — run a production build first.';
        dialog.showModal();
        return;
      }
    }

    // Mount the UI if the container is empty (first open, or after DOM swap).
    const container = document.getElementById('search-pagefind');
    if (container && !container.firstChild) {
      try {
        new _w.PagefindUI({
          element: '#search-pagefind',
          showSubResults: true,
          showImages: false,
          resetStyles: false,
          baseUrl: base || '/',
          bundlePath: `${base}/pagefind/`,
        });
      } catch (err) {
        console.error('[Search] PagefindUI init failed:', err);
      }
    }

    dialog.showModal();
    requestAnimationFrame(() => {
      (dialog.querySelector('input') as HTMLInputElement | null)?.focus();
    });
  }

  // All listeners go on `document` so they survive ClientRouter DOM swaps.
  // The window flag ensures they are registered only once (script runs once,
  // but guard is here for safety in case the behaviour changes).
  if (!_w.__searchListeners) {
    _w.__searchListeners = true;

    // Button click — delegate so the listener survives trigger DOM replacement.
    document.addEventListener('click', (e) => {
      if ((e.target as Element | null)?.closest('#search-trigger')) openSearch();
    });

    // Keyboard shortcut
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        const dialog = document.getElementById('search-dialog') as HTMLDialogElement | null;
        if (dialog?.open) dialog.close(); else openSearch();
      }
    });

    // Backdrop click closes the dialog
    document.addEventListener('click', (e: MouseEvent) => {
      const dialog = document.getElementById('search-dialog') as HTMLDialogElement | null;
      if (dialog && e.target === dialog) dialog.close();
    });

    // Close on navigation
    document.addEventListener('astro:page-load', () => {
      const dialog = document.getElementById('search-dialog') as HTMLDialogElement | null;
      dialog?.close();
    });
  }
</script>

<style is:global>
  /* ── Trigger button ─────────────────────────────────────────────────────── */

  .search-trigger {
    width: 10rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--sl-color-hairline-shade);
    border-radius: 0.375rem;
    background: var(--sl-color-bg);
    color: var(--sl-color-gray-3);
    font-size: 0.75rem;
    cursor: pointer;
    white-space: nowrap;
    transition: border-color 0.15s, color 0.15s;
  }

  .search-trigger:hover {
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent);
  }

  .search-trigger-hint {
    font-size: 0.65rem;
    opacity: 0.7;
  }

  @media (max-width: 50rem) {
    .search-trigger-hint { display: none; }
    .search-trigger { border: none; background: none; padding: 0.25rem; }
  }

  /* ── Modal dialog ───────────────────────────────────────────────────────── */

  .search-dialog {
    position: fixed;
    inset: 0;
    margin: 5rem auto auto;
    width: 90%;
    max-width: 40rem;
    max-height: calc(100vh - 8rem);
    padding: 0;
    border: 1px solid var(--sl-color-hairline-shade);
    border-radius: 0.5rem;
    background: var(--sl-color-bg);
    box-shadow: var(--sl-shadow-lg);
    overflow: hidden;
  }

  .search-dialog::backdrop {
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(2px);
  }

  .search-dialog-inner {
    overflow-y: auto;
    max-height: calc(100vh - 8rem);
  }

  /* ── Pagefind UI overrides — map to --sl-* tokens ───────────────────────── */

  .search-dialog {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: var(--sl-color-accent);
    --pagefind-ui-text: var(--sl-color-text);
    --pagefind-ui-background: var(--sl-color-bg);
    --pagefind-ui-border: var(--sl-color-hairline-shade);
    --pagefind-ui-tag: var(--sl-color-bg-sidebar);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0.375rem;
    --pagefind-ui-font: inherit;
  }

  /* Remove pagefind's built-in margin/padding on the wrapper */
  #search-pagefind .pagefind-ui {
    padding: 0.75rem;
  }

  #search-pagefind .pagefind-ui__search-input {
    border-radius: 0.375rem;
  }

  #search-pagefind .pagefind-ui__result {
    border-top: 1px solid var(--sl-color-hairline);
  }

  #search-pagefind .pagefind-ui__result-link {
    color: var(--sl-color-accent);
  }
</style>
