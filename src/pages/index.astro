---
import DocsLayout from 'igniteui-astro-components/layouts/DocsLayout.astro';
---

<DocsLayout hasSidebar={false}>
  <div class="hero">
    <h1>Ignite UI for Angular</h1>
    <p class="tagline">
      A complete library of Angular UI components including Data Grid, Charts, Gauges, and more.
    </p>
    <div class="hero-actions">
      <a href="/general/getting-started/" class="btn btn-primary">Get Started</a>
      <a href="/accordion/" class="btn btn-secondary">Components</a>
    </div>
    <h2>Overview</h2>
    <p>
      Ignite UI for Angular provides a complete set of Material-based UI components,
      directives, and supporting services for building modern web applications with Angular.
    </p>
    <p>
      Explore the documentation to learn about individual components, theming, and more.
    </p>
  </div>
</DocsLayout>

<style>
  .hero {
    max-width: 50rem;
    margin: 0 auto;
    padding: 4rem 1.5rem 2rem;
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-block: 0 0.5rem;
    color: var(--sl-color-text);
  }

  .tagline {
    font-size: 1.125rem;
    color: var(--sl-color-gray-3);
    margin-block: 0 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-block-end: 3rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1.25rem;
    border-radius: 0.375rem;
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .btn:hover { opacity: 0.85; text-decoration: none; }

  .btn-primary {
    background: var(--sl-color-accent);
    color: #fff;
  }

  .btn-secondary {
    background: transparent;
    color: var(--sl-color-text-accent);
    border: 1px solid var(--sl-color-accent);
  }
</style>
