---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="IgniteUI Docs Template" description="A starter Astro documentation template by IgniteUI.">
  <section style="padding: 3rem 0;">
    <h1 style="font-size: 2.5rem; font-weight: 700; margin-bottom: 1rem;">
      📄 IgniteUI Docs Template
    </h1>
    <p style="font-size: 1.15rem; color: #374151; max-width: 600px; margin-bottom: 2rem;">
      A minimal, fast, and extensible Astro-powered documentation starter template for IgniteUI projects.
    </p>
    <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
      <a
        href="https://docs.astro.build"
        target="_blank"
        rel="noopener noreferrer"
        style="padding: 0.6rem 1.25rem; background: #1e293b; color: white; border-radius: 6px; text-decoration: none; font-weight: 500;"
      >
        Astro Docs &rarr;
      </a>
      <a
        href="https://github.com/IgniteUI/docs-template"
        target="_blank"
        rel="noopener noreferrer"
        style="padding: 0.6rem 1.25rem; background: #e5e7eb; color: #111827; border-radius: 6px; text-decoration: none; font-weight: 500;"
      >
        GitHub &rarr;
      </a>
    </div>
  </section>

  <section style="margin-top: 2rem;">
    <h2 style="font-size: 1.5rem; font-weight: 600; margin-bottom: 1rem;">🚀 Getting Started</h2>
    <pre style="background: #1e293b; color: #e2e8f0; padding: 1.25rem; border-radius: 8px; overflow-x: auto; font-size: 0.9rem;"><code>git clone https://github.com/IgniteUI/docs-template.git my-docs
cd my-docs
npm install
npm run dev</code></pre>
  </section>
</BaseLayout>