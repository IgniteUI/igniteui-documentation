---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---

<StarlightPage
  frontmatter={{
    title: 'Ignite UI for Angular',
    description: 'A complete library of Angular UI components for building modern, high-performance web applications.',
    template: 'splash',
    hero: {
      title: 'Ignite UI for Angular',
      tagline:
        'A complete library of Angular UI components including Data Grid, Charts, Gauges, and more.',
      actions: [
        {
          text: 'Get Started',
          link: '/general/getting-started/',
          icon: 'right-arrow',
        },
        {
          text: 'Components',
          link: '/accordion/',
          variant: 'minimal',
        },
      ],
    },
  }}
>
  <h2>Overview</h2>
  <p>
    Ignite UI for Angular provides a complete set of Material-based UI components,
    directives, and supporting services for building modern web applications with Angular.
  </p>
  <p>Explore the documentation to learn about individual components, theming, and more.</p>
</StarlightPage>
