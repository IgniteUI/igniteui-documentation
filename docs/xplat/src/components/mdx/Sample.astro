---
/**
 * Renders a live demo widget with source code tabs and live-edit buttons.
 *
 * Usage:
 *   <Sample src="/charts/data-chart/axis-crossing" height={500} alt="{platform} Example" />
 *
 * The `alt` prop supports the "{platform}" placeholder resolved at build time.
 *
 * The widget HTML shell is rendered server-side by Astro; client-side behaviour
 * (iframe serial loading, code-tab fetching, tab switching, StackBlitz / CodeSandbox)
 * is handled by src/scripts/sample-widget.ts which is imported via the
 * deduplicated <script> below — it runs once per page regardless of how many
 * <Sample> components appear.
 */
import { getPlatformContext, getEnvVars } from '../../lib/platform-context';

interface Props {
    src: string;
    height?: number;
    alt?: string;
}

const { src, height = 400, alt = '' } = Astro.props;
const { name, lower } = getPlatformContext();
const env = getEnvVars();

const demosBaseUrl = (env.dvDemosBaseUrl ?? '').replace(/\/$/, '');
const resolvedAlt  = alt.replace('{platform}', name);
const iframeSrc    = `${demosBaseUrl}${src}`;
const githubSrc    = src.replace(/^\//, '');

// Stable, unique element ID derived from the sample path.
const widgetId     = 'cw' + src.replace(/[^a-z0-9]/gi, '-');
const exampleTabId = `${widgetId}-example`;
---

<div class="code-view"
     id={widgetId}
     data-iframe-src={iframeSrc}
     data-demos-base-url={demosBaseUrl}
     data-github-src={githubSrc}
     data-platform={lower}>
  <div class="code-view-navbar">
    <div class="code-view-tab code-view-tab--active" data-tab-id={exampleTabId}>EXAMPLE</div>
    <span class="fs-button-container" title="Expand to fullscreen"></span>
  </div>
  <div class="code-views-container">
    <div id={exampleTabId}
         class="sample-container code-view-tab-content loading"
         style={`height: ${height}px`}>
      <iframe
        data-src={iframeSrc}
        title={resolvedAlt}
        style="width: 100%; height: 100%;"
        frameborder="0"
        seamless
      ></iframe>
    </div>
  </div>
</div>

<div class="divider--half"></div>

<script>
  // Astro deduplicates module scripts — this runs exactly once per page even
  // when multiple <Sample> components are present.
  import { initSampleWidgets } from '../../scripts/sample-widget';
  initSampleWidgets();
</script>
