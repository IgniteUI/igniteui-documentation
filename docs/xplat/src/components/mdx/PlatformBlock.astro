---
/**
 * Renders its slotted content only when the current build platform matches.
 *
 * Replaces the fragile comment-block pattern:
 *   <!-- Angular, React -->…<!-- end: Angular, React -->
 *
 * Usage:
 *   <PlatformBlock for="Angular, React">
 *     This paragraph only appears in Angular and React docs.
 *   </PlatformBlock>
 */
import { getPlatformContext } from '../../lib/platform-context';

interface Props {
    /** Comma-separated list of platform names to show content for. */
    for: string;
}

const { for: forProp } = Astro.props;
const allowed = forProp.split(',').map((s) => s.trim());
const { name } = getPlatformContext();
---
{allowed.includes(name) && <slot />}
