{
  "name": "xplat-docs",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",

    "generate": "node scripts/generate.mjs",
    "generate:angular": "node scripts/generate.mjs --platform=Angular",
    "generate:react": "node scripts/generate.mjs --platform=React",
    "generate:webcomponents": "node scripts/generate.mjs --platform=WebComponents",
    "generate:blazor": "node scripts/generate.mjs --platform=Blazor",
    "generate:angular:jp": "node scripts/generate.mjs --platform=Angular --lang=jp",
    "generate:react:jp": "node scripts/generate.mjs --platform=React --lang=jp",
    "generate:webcomponents:jp": "node scripts/generate.mjs --platform=WebComponents --lang=jp",
    "generate:blazor:jp": "node scripts/generate.mjs --platform=Blazor --lang=jp",

    "dev:angular": "npm run generate:angular && astro dev --port 4331",
    "dev:react": "npm run generate:react && astro dev --port 4332",
    "dev:webcomponents": "npm run generate:webcomponents && astro dev --port 4333",
    "dev:blazor": "npm run generate:blazor && astro dev --port 4334",
    "dev:angular:jp": "npm run generate:angular:jp && astro dev --port 4331",
    "dev:react:jp": "npm run generate:react:jp && astro dev --port 4332",
    "dev:webcomponents:jp": "npm run generate:webcomponents:jp && astro dev --port 4333",
    "dev:blazor:jp": "npm run generate:blazor:jp && astro dev --port 4334",

    "build:angular": "npm run generate:angular && astro build",
    "build:react": "npm run generate:react && astro build",
    "build:webcomponents": "npm run generate:webcomponents && astro build",
    "build:blazor": "npm run generate:blazor && astro build",
    "build:angular:jp": "npm run generate:angular:jp && astro build",
    "build:react:jp": "npm run generate:react:jp && astro build",
    "build:webcomponents:jp": "npm run generate:webcomponents:jp && astro build",
    "build:blazor:jp": "npm run generate:blazor:jp && astro build",

    "build-staging:angular": "cross-env NODE_ENV=staging npm run build:angular",
    "build-staging:react": "cross-env NODE_ENV=staging npm run build:react",
    "build-staging:webcomponents": "cross-env NODE_ENV=staging npm run build:webcomponents",
    "build-staging:blazor": "cross-env NODE_ENV=staging npm run build:blazor",
    "build-staging:angular:jp": "cross-env NODE_ENV=staging npm run build:angular:jp",
    "build-staging:react:jp": "cross-env NODE_ENV=staging npm run build:react:jp",
    "build-staging:webcomponents:jp": "cross-env NODE_ENV=staging npm run build:webcomponents:jp",
    "build-staging:blazor:jp": "cross-env NODE_ENV=staging npm run build:blazor:jp",

    "build-production:angular": "cross-env NODE_ENV=production npm run build:angular",
    "build-production:react": "cross-env NODE_ENV=production npm run build:react",
    "build-production:webcomponents": "cross-env NODE_ENV=production npm run build:webcomponents",
    "build-production:blazor": "cross-env NODE_ENV=production npm run build:blazor",
    "build-production:angular:jp": "cross-env NODE_ENV=production npm run build:angular:jp",
    "build-production:react:jp": "cross-env NODE_ENV=production npm run build:react:jp",
    "build-production:webcomponents:jp": "cross-env NODE_ENV=production npm run build:webcomponents:jp",
    "build-production:blazor:jp": "cross-env NODE_ENV=production npm run build:blazor:jp"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.38.2",
    "astro": "^6.0.1",
    "docs-template": "file:../../",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "js-yaml": "^4.1.1",
    "sass-embedded": "^1.98.0"
  }
}
