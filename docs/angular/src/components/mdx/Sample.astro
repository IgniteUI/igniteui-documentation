---
/**
 * Angular Sample component — renders a live demo widget.
 *
 * Usage in Angular MDX files:
 *   <Sample src="/notifications/banner-sample-1/" height={530} alt="Angular Banner Example" />
 *
 * Reads base URLs from environment.json (demosBaseUrl / dvDemosBaseUrl) using
 * DOCS_SOURCE_PATH and DOCS_ENV, matching the same logic as remark-docfx.ts.
 *
 * DV samples (charts/, gauges/, maps/, excel/) automatically use dvDemosBaseUrl.
 */
import fs from 'node:fs';
import path from 'node:path';

interface Props {
    src: string;
    height?: number;
    alt?: string;
}

const { src, height = 400, alt = '' } = Astro.props;

function loadEnv(): Record<string, string> {
    const sourcePath = process.env.DOCS_SOURCE_PATH;
    if (!sourcePath) return {};
    const sourceRoot = path.resolve(sourcePath);
    const parent     = path.dirname(sourceRoot);
    const candidates = [
        path.join(sourceRoot, 'en', 'environment.json'),
        path.join(sourceRoot, 'environment.json'),
        path.join(parent, 'environment.json'),
        path.join(parent, 'en', 'environment.json'),
    ];
    const envPath = candidates.find(c => fs.existsSync(c));
    if (!envPath) return {};
    try {
        const data   = JSON.parse(fs.readFileSync(envPath, 'utf-8'));
        const envKey = process.env.DOCS_ENV ?? process.env.NODE_ENV ?? 'production';
        return data[envKey] ?? data.production ?? {};
    } catch { return {}; }
}

const env = loadEnv() as Record<string, string>;

// DV samples (charts, gauges, maps, excel) use a separate base URL.
const DV_PREFIXES = ['gauges/', 'maps/', 'excel/', 'charts/'];
const srcNoSlash  = src.replace(/^\//, '');
const isDv        = DV_PREFIXES.some(p => srcNoSlash.startsWith(p));
const baseUrl     = ((isDv ? env.dvDemosBaseUrl : env.demosBaseUrl) ?? env.dvDemosBaseUrl ?? '').replace(/\/$/, '');

const iframeSrc   = `${baseUrl}${src}`;
// githubSrc strips the leading slash for use in GH URLs
const githubSrc   = srcNoSlash;

const widgetId    = 'cw' + src.replace(/[^a-z0-9]/gi, '-');
const exampleTabId = `${widgetId}-example`;
---

<div class="code-view"
     id={widgetId}
     data-iframe-src={iframeSrc}
     data-demos-base-url={baseUrl}
     data-github-src={githubSrc}
     data-platform="angular">
  <div class="code-view-navbar">
    <div class="code-view-tab code-view-tab--active" data-tab-id={exampleTabId}>EXAMPLE</div>
    <span class="fs-button-container" title="Expand to fullscreen"></span>
  </div>
  <div class="code-views-container">
    <div id={exampleTabId}
         class="sample-container code-view-tab-content loading"
         style={`height: ${height}px`}>
      <iframe
        data-src={iframeSrc}
        title={alt}
        style="width: 100%; height: 100%;"
        frameborder="0"
        seamless
      ></iframe>
    </div>
  </div>
</div>

<div class="divider--half"></div>

<script>
  // Astro deduplicates module scripts — runs exactly once per page.
  import { initSampleWidgets } from '../../scripts/sample-widget';
  initSampleWidgets();
</script>
