{
  "name": "angular-docs",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "sync:en": "node scripts/sync-docfx.mjs --lang=en",
    "sync:jp": "node scripts/sync-docfx.mjs --lang=jp",
    "sync:kr": "node scripts/sync-docfx.mjs --lang=kr",
    "dev": "astro dev --port 4321",
    "dev:en": "cross-env DOCS_LANG=en astro dev --port 4321",
    "dev:jp": "cross-env DOCS_LANG=jp astro dev --port 4321",
    "dev:kr": "cross-env DOCS_LANG=kr astro dev --port 4321",
    "build": "astro build",
    "build:en": "cross-env DOCS_LANG=en astro build",
    "build:jp": "cross-env DOCS_LANG=jp astro build",
    "build:kr": "cross-env DOCS_LANG=kr astro build",
    "build-staging": "cross-env NODE_ENV=staging astro build --outDir=../../dist/angular",
    "build-staging:en": "cross-env NODE_ENV=staging DOCS_LANG=en astro build --outDir=../../dist/angular",
    "build-staging:jp": "cross-env NODE_ENV=staging DOCS_LANG=jp astro build --outDir=../../dist/angular",
    "build-staging:kr": "cross-env NODE_ENV=staging DOCS_LANG=kr astro build --outDir=../../dist/angular",
    "build-production": "cross-env NODE_ENV=production astro build --outDir=../../dist/angular",
    "build-production:en": "cross-env NODE_ENV=production DOCS_LANG=en astro build --outDir=../../dist/angular",
    "build-production:jp": "cross-env NODE_ENV=production DOCS_LANG=jp astro build --outDir=../../dist/angular",
    "build-production:kr": "cross-env NODE_ENV=production DOCS_LANG=kr astro build --outDir=../../dist/angular",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.38.2",
    "astro": "^6.0.1",
    "sharp": "^0.34.2",
    "docs-template": "file:../../"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "js-yaml": "^4.1.1",
    "sass-embedded": "^1.98.0"
  }
}
